---
import DocLayout from '../../layouts/DocLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = `${base}guides/patterns`;
---

<DocLayout
  title="Common Patterns"
  description="Reusable UI patterns built with Storyhouse components — form layouts, navigation, data display, and responsive design."
  currentPath={currentPath}
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      This guide covers common UI patterns and compositions using Storyhouse components.
      These patterns are battle-tested and represent the recommended approach for building
      consistent interfaces.
    </p>
  </section>

  <section>
    <h2 id="form">Form Patterns</h2>

    <h3>Login Form</h3>
    <p>A standard login form with email input, password input, and submit button.</p>

    <CodeBlock title="login-form.tsx" code={`import React from 'react';
import { Card, CardHeader, CardTitle, CardContent, CardFooter } from '@storyhouse/components';
import { Input, Button } from '@storyhouse/components';

export function LoginForm() {
  const [email, setEmail] = React.useState('');
  const [password, setPassword] = React.useState('');
  const [isLoading, setIsLoading] = React.useState(false);

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setIsLoading(true);
    // … API call
    setIsLoading(false);
  };

  return (
    <Card variant="elevated" padding="lg" className="w-full max-w-md">
      <form onSubmit={handleSubmit}>
        <CardHeader>
          <CardTitle as="h2">Sign In</CardTitle>
        </CardHeader>
        <CardContent className="space-y-4">
          <Input
            label="Email"
            type="email"
            placeholder="you@example.com"
            value={email}
            onChange={(e) => setEmail(e.target.value)}
            leftIcon={<MailIcon />}
            fullWidth
          />
          <Input
            label="Password"
            type="password"
            placeholder="Enter your password"
            value={password}
            onChange={(e) => setPassword(e.target.value)}
            leftIcon={<LockIcon />}
            fullWidth
          />
        </CardContent>
        <CardFooter>
          <Button type="submit" isLoading={isLoading} fullWidth>
            {isLoading ? 'Signing in…' : 'Sign In'}
          </Button>
        </CardFooter>
      </form>
    </Card>
  );
}`} />

    <h3>Inline Search Bar</h3>
    <p>A responsive search bar with icon and full-width support.</p>

    <CodeBlock title="search-bar.tsx" code={`import React from 'react';
import { Input, Button } from '@storyhouse/components';

export function SearchBar() {
  const [query, setQuery] = React.useState('');

  return (
    <div className="flex w-full max-w-xl gap-2">
      <Input
        placeholder="Search resources…"
        value={query}
        onChange={(e) => setQuery(e.target.value)}
        leftIcon={<SearchIcon />}
        fullWidth
      />
      <Button variant="primary">Search</Button>
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="navigation">Navigation Patterns</h2>

    <h3>Tab-Like Navigation with Badges</h3>
    <p>Use Badge for item counts or status indicators alongside nav labels.</p>

    <CodeBlock title="nav-with-badges.tsx" code={`import { Badge } from '@storyhouse/components';

const navItems = [
  { label: 'Inbox', count: 12 },
  { label: 'Sent', count: 0 },
  { label: 'Drafts', count: 3 },
  { label: 'Spam', count: 8 },
];

export function NavWithBadges() {
  return (
    <nav className="space-y-1">
      {navItems.map((item) => (
        <a
          key={item.label}
          href="#"
          className="flex items-center justify-between rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800"
        >
          <span>{item.label}</span>
          {item.count > 0 && (
            <Badge variant="neutral" size="sm">
              {item.count > 99 ? '99+' : item.count}
            </Badge>
          )}
        </a>
      ))}
    </nav>
  );
}`} />

    <h3>User Menu</h3>
    <p>A user dropdown trigger combining Avatar and a button trigger.</p>

    <CodeBlock title="user-menu.tsx" code={`import { Avatar, Button, Badge } from '@storyhouse/components';

export function UserMenu() {
  return (
    <div className="flex items-center gap-3">
      <Avatar
        src="/avatars/jane.jpg"
        name="Jane Doe"
        size="sm"
        alt="Jane Doe"
      />
      <div className="hidden sm:block">
        <p className="text-sm font-medium text-gray-900 dark:text-white">Jane Doe</p>
        <div className="flex items-center gap-1">
          <Badge variant="success" size="sm" dot>Online</Badge>
        </div>
      </div>
      <Button variant="ghost" size="sm" aria-label="Open menu">
        <ChevronDownIcon />
      </Button>
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="data-display">Data Display Patterns</h2>

    <h3>User Profile Card</h3>
    <p>Combining Avatar with Card for user profile displays.</p>

    <CodeBlock title="profile-card.tsx" code={`import { Card, CardHeader, CardTitle, CardContent, Button, Avatar, Badge } from '@storyhouse/components';

export function ProfileCard() {
  return (
    <Card variant="default" padding="md" className="w-full max-w-sm">
      <CardHeader>
        <Avatar name="Jane Doe" size="lg" alt="Jane Doe" />
        <div>
          <CardTitle as="h3">Jane Doe</CardTitle>
          <p className="text-sm text-gray-500">jane@example.com</p>
        </div>
      </CardHeader>
      <CardContent>
        <p className="text-sm text-gray-600">
          Product designer with 10+ years of experience building design systems.
        </p>
        <div className="mt-3 flex flex-wrap gap-1.5">
          <Badge variant="primary" size="sm">Design</Badge>
          <Badge variant="success" size="sm">Figma</Badge>
          <Badge variant="warning" size="sm">React</Badge>
        </div>
      </CardContent>
      <CardFooter>
        <Button variant="primary" size="sm" fullWidth>View Profile</Button>
      </CardFooter>
    </Card>
  );
}`} />

    <h3>Metric Dashboard Widget</h3>
    <p>A dashboard card showing key metrics with a sparkline and comparison.</p>

    <CodeBlock title="metric-widget.tsx" code={`import { Card, CardHeader, CardTitle, CardContent } from '@storyhouse/components';
import { Badge } from '@storyhouse/components';

export function MetricWidget() {
  return (
    <Card variant="elevated" padding="lg">
      <CardHeader>
        <CardTitle as="h3">Monthly Revenue</CardTitle>
        <Badge variant="success" size="sm" dot>+12.5%</Badge>
      </CardHeader>
      <CardContent>
        <p className="text-3xl font-bold text-gray-900 dark:text-white">$48,250</p>
        <p className="mt-1 text-sm text-gray-500">vs $42,890 last month</p>
      </CardContent>
    </Card>
  );
}`} />
  </section>

  <section>
    <h2 id="responsive">Responsive Patterns</h2>

    <h3>Responsive Card Grid</h3>
    <p>A card grid that goes from 1 column on mobile to 3 columns on desktop.</p>

    <CodeBlock title="card-grid.tsx" code={`import { Card, CardHeader, CardTitle, CardContent, Badge } from '@storyhouse/components';

export function CardGrid() {
  return (
    <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <Card key={item.id} variant="default">
          <CardHeader>
            <CardTitle as="h3">{item.title}</CardTitle>
            <Badge variant={item.status}>{item.status}</Badge>
          </CardHeader>
          <CardContent>
            <p className="text-sm text-gray-600">{item.description}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  );
}`} />

    <h3>Mobile-Friendly Settings Form</h3>
    <p>Use <code>fullWidth</code> on inputs and buttons for touch-friendly mobile layouts.</p>

    <CodeBlock title="settings-form.tsx" code={`import { Card, CardHeader, CardTitle, CardContent, CardFooter, Input, Button } from '@storyhouse/components';

export function SettingsForm() {
  return (
    <Card className="w-full max-w-lg">
      <CardHeader>
        <CardTitle as="h2">Account Settings</CardTitle>
      </CardHeader>
      <CardContent className="space-y-4">
        <Input label="Display Name" fullWidth />
        <Input label="Email" type="email" fullWidth />
      </CardContent>
      <CardFooter className="flex-col gap-2 sm:flex-row">
        <Button variant="secondary" fullWidth sm:fullWidth={false}>
          Cancel
        </Button>
        <Button variant="primary" fullWidth sm:fullWidth={false}>
          Save Changes
        </Button>
      </CardFooter>
    </Card>
  );
}`} />
  </section>
</DocLayout>
