---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
---

<Layout title="Guides" description="Learn how to use the Storyhouse design system effectively.">
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-white">Guides</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Learn how to install, configure, and customize the Storyhouse design system.
      </p>
    </div>

    <div class="mt-12 mx-auto max-w-3xl space-y-6">
      <a href={`${base}guides/getting-started`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-blue-100 dark:bg-blue-950">
            <svg class="h-7 w-7 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Getting Started</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Install the design system packages and configure them in your project. Covers npm setup, TypeScript configuration, and basic usage patterns.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>

      <a href={`${base}tokens`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-green-100 dark:bg-green-950">
            <svg class="h-7 w-7 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Design Tokens</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Understanding colors, typography, spacing, and shadow tokens. Available as CSS custom properties and JavaScript exports.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Browse tokens →</span>
          </div>
        </div>
      </a>

      <a href={`${base}guides/theming`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-purple-100 dark:bg-purple-950">
            <svg class="h-7 w-7 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Theming Guide</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Customize the design system to match your brand. Learn about CSS variable overrides, dark mode, and token customization.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</Layout>
