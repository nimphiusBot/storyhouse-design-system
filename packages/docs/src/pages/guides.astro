---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
---

<Layout title="Guides" description="Learn how to use the Storyhouse design system effectively.">
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-white">Guides</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Learn how to install, configure, and customize the Storyhouse design system.
      </p>
    </div>

    <div class="mt-12 mx-auto max-w-3xl space-y-6">
      <a href={`${base}guides/getting-started`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-blue-100 dark:bg-blue-950">
            <svg class="h-7 w-7 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Getting Started</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Install the design system packages and configure them in your project. Covers npm setup, TypeScript configuration, and basic usage patterns.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>

      <a href={`${base}tokens`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-green-100 dark:bg-green-950">
            <svg class="h-7 w-7 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Design Tokens</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Understanding colors, typography, spacing, and shadow tokens. Available as CSS custom properties and JavaScript exports.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Browse tokens →</span>
          </div>
        </div>
      </a>

      <a href={`${base}guides/theming`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-purple-100 dark:bg-purple-950">
            <svg class="h-7 w-7 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Theming Guide</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Customize the design system to match your brand. Learn about CSS variable overrides, dark mode, and token customization.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>

      <a href={`${base}guides/utilities`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-green-100 dark:bg-green-950">
            <svg class="h-7 w-7 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Utilities</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Learn about the cn() class merge utility, TypeScript helpers, and Tailwind integration utilities shipped with Storyhouse.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>

      <a href={`${base}guides/patterns`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-pink-100 dark:bg-pink-950">
            <svg class="h-7 w-7 text-pink-600 dark:text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Common Patterns</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Reusable UI patterns built with Storyhouse — form layouts, navigation, data display cards, responsive grids, and user menus.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">View patterns →</span>
          </div>
        </div>
      </a>

      <a href={`${base}guides/contributing`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-orange-100 dark:bg-orange-950">
            <svg class="h-7 w-7 text-orange-600 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Contributing</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Guidelines for contributing to Storyhouse — component structure, coding standards, Storybook stories, testing, and PR process.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>

      <a href={`${base}guides/migration`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-amber-100 dark:bg-amber-950">
            <svg class="h-7 w-7 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Migration Guide</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Upgrade between Storyhouse versions with confidence. Covers breaking changes, deprecations, API notes, and the upgrade checklist.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Read guide →</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</Layout>
