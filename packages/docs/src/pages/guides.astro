---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl">Guides</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        Learn how to use the Storyhouse design system effectively.
      </p>
    </div>

    <div class="mt-12 space-y-6">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Getting Started</h3>
        <p class="mt-2 text-sm text-gray-600">Install the design system packages and configure them in your project.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Design Tokens</h3>
        <p class="mt-2 text-sm text-gray-600">Understanding colors, typography, spacing, and shadow tokens.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Theming</h3>
        <p class="mt-2 text-sm text-gray-600">Customize the design system to match your brand.</p>
      </div>
    </div>
  </div>
</Layout>
