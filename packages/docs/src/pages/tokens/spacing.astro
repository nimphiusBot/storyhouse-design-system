---
import DocLayout from '../../layouts/DocLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = `${base}tokens/spacing`;
---

<DocLayout
  title="Spacing &amp; Shadows"
  description="4px-grid spacing scale, box shadows, drop shadows, border radius, and opacity tokens."
  currentPath={currentPath}
>
  <section>
    <h2 id="spacing-scale">Spacing Scale</h2>
    <p>
      The spacing scale follows a 4px grid (1 unit = 0.25rem) with increments from 0 to 24rem.
      This provides a consistent rhythm across all components.
    </p>

    <div class="my-6 overflow-hidden rounded-xl border border-gray-200 shadow-sm dark:border-gray-800">
      <table class="min-w-full">
        <tbody>
          {[
            { token: '0', value: '0px' },
            { token: 'px', value: '1px' },
            { token: '0.5', value: '0.125rem', demo: '2px' },
            { token: '1', value: '0.25rem', demo: '4px' },
            { token: '1.5', value: '0.375rem', demo: '6px' },
            { token: '2', value: '0.5rem', demo: '8px' },
            { token: '3', value: '0.75rem', demo: '12px' },
            { token: '4', value: '1rem', demo: '16px' },
            { token: '5', value: '1.25rem', demo: '20px' },
            { token: '6', value: '1.5rem', demo: '24px' },
            { token: '8', value: '2rem', demo: '32px' },
            { token: '10', value: '2.5rem', demo: '40px' },
            { token: '12', value: '3rem', demo: '48px' },
            { token: '16', value: '4rem', demo: '64px' },
            { token: '20', value: '5rem', demo: '80px' },
            { token: '24', value: '6rem', demo: '96px' },
          ].map((s) => (
            <tr class="border-b border-gray-100 last:border-0 dark:border-gray-800">
              <td class="px-4 py-3 whitespace-nowrap">
                <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">--spacing-{s.token}</code>
              </td>
              <td class="px-4 py-3 font-mono text-sm text-gray-500 dark:text-gray-400">{s.value}</td>
              <td class="hidden px-4 py-3 sm:table-cell">
                <div class="flex items-center gap-2">
                  <div style={s.demo ? `width: ${s.demo}; height: 1rem; background: #f97316; border-radius: 2px;` : ''}></div>
                  {s.demo && <span class="text-xs text-gray-400">{s.demo}</span>}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <CodeBlock lang="css" title="usage.css" code={`.card {
  padding: var(--spacing-6);   /* 1.5rem — card padding */
  gap: var(--spacing-4);       /* 1rem — component gap */
  margin-bottom: var(--spacing-8); /* 2rem — section margin */
}

.button-group {
  display: flex;
  gap: var(--spacing-2);       /* 0.5rem — button spacing */
}`} />
  </section>

  <section>
    <h2 id="box-shadows">Box Shadows</h2>
    <p>Six shadow levels plus inner and none, progressing from subtle to dramatic.</p>

    <div class="my-6 grid gap-6 sm:grid-cols-2">
      {[
        { name: 'sm', css: '0 1px 2px 0 rgb(0 0 0 / 0.05)' },
        { name: 'base', css: '0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)' },
        { name: 'md', css: '0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)' },
        { name: 'lg', css: '0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)' },
        { name: 'xl', css: '0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)' },
        { name: '2xl', css: '0 25px 50px -12px rgb(0 0 0 / 0.25)' },
      ].map((s) => (
        <div key={s.name} class="rounded-xl bg-white p-6" style={`box-shadow: var(--shadow-${s.name})`}>
          <code class="text-xs font-medium text-gray-700">--shadow-{s.name}</code>
          <p class="mt-1 text-xs text-gray-500">{s.css}</p>
        </div>
      ))}
    </div>

    <CodeBlock lang="css" title="shadows.css" code={`/* Available shadow tokens */
--shadow-sm:   0 1px 2px 0 rgb(0 0 0 / 0.05);
--shadow-base: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
--shadow-md:   0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
--shadow-lg:   0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
--shadow-xl:   0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
--shadow-2xl:  0 25px 50px -12px rgb(0 0 0 / 0.25);
--shadow-inner: inset 0 2px 4px 0 rgb(0 0 0 / 0.05);
--shadow-none: none;`} />
  </section>

  <section>
    <h2 id="border-radius">Border Radius</h2>

    <div class="my-6 overflow-hidden rounded-xl border border-gray-200 shadow-sm dark:border-gray-800">
      <table class="min-w-full">
        <tbody>
          {[
            { token: 'none', value: '0px' },
            { token: 'sm', value: '0.125rem' },
            { token: 'base', value: '0.25rem' },
            { token: 'md', value: '0.375rem' },
            { token: 'lg', value: '0.5rem' },
            { token: 'xl', value: '0.75rem' },
            { token: '2xl', value: '1rem' },
            { token: '3xl', value: '1.5rem' },
            { token: 'full', value: '9999px' },
          ].map((r) => (
            <tr class="border-b border-gray-100 last:border-0 dark:border-gray-800">
              <td class="px-4 py-3 font-mono text-sm"><code>--radius-{r.token}</code></td>
              <td class="px-4 py-3 font-mono text-sm text-gray-500 dark:text-gray-400">{r.value}</td>
              <td class="px-4 py-3">
                <div class="h-6 w-16 bg-orange-500" style={`border-radius: var(--radius-${r.token})`}></div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2 id="opacity">Opacity</h2>
    <p>A 16-step opacity scale from 0 to 1.</p>

    <div class="my-6 overflow-hidden rounded-xl border border-gray-200 shadow-sm dark:border-gray-800">
      <table class="min-w-full">
        <tbody>
          {[
            { token: '0', value: '0' },
            { token: '5', value: '0.05' },
            { token: '10', value: '0.1' },
            { token: '20', value: '0.2' },
            { token: '30', value: '0.3' },
            { token: '40', value: '0.4' },
            { token: '50', value: '0.5' },
            { token: '60', value: '0.6' },
            { token: '70', value: '0.7' },
            { token: '75', value: '0.75' },
            { token: '80', value: '0.8' },
            { token: '90', value: '0.9' },
            { token: '95', value: '0.95' },
            { token: '100', value: '1' },
          ].map((o) => (
            <tr class="border-b border-gray-100 last:border-0 dark:border-gray-800">
              <td class="px-4 py-3 font-mono text-sm"><code>--opacity-{o.token}</code></td>
              <td class="px-4 py-3 font-mono text-sm text-gray-500 dark:text-gray-400">{o.value}</td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1">
                  <div class="h-6 w-16 rounded bg-orange-500" style={`opacity: ${o.value}`}></div>
                  <span class="w-8 text-xs text-gray-400">{o.token}%</span>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DocLayout>
