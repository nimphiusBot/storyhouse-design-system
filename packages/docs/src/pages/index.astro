---

<Layout title="Storyhouse Design System" description="An elite design system built for scale, precision, and developer experience.">
  <!-- Hero -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="py-20 text-center lg:py-28">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-orange-500 shadow-lg shadow-orange-500/25">
        <span class="text-3xl font-bold text-white">S</span>
      </div>
      <h1 class="mt-8 text-balance text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl lg:text-7xl dark:text-white">
        Storyhouse
        <span class="block bg-gradient-to-r from-orange-500 to-orange-600 bg-clip-text text-transparent">Design System</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-balance text-lg leading-8 text-gray-600 dark:text-gray-400">
        An elite design system built for enterprise scale. Production-ready components,
        comprehensive design tokens, and exceptional developer experience — all powered by
        TypeScript, Storybook, and Astro.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a
          href={`${base}guides/getting-started`}
          class="inline-flex items-center justify-center rounded-lg bg-orange-500 px-6 py-3 text-base font-semibold text-white shadow-sm transition-all hover:bg-orange-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2"
        >
          Get Started
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href={`${base}components`}
          class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-6 py-3 text-base font-semibold text-gray-700 shadow-sm transition-all hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 focus-visible:ring-offset-2 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        >
          Browse Components
        </a>
      </div>
    </div>
  </div>

  <!-- Stats / Metrics -->
  <div class="border-t border-gray-200 bg-gray-50 py-16 dark:border-gray-800 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div class="text-center">
          <p class="text-4xl font-bold text-gray-900 dark:text-white">40</p>
          <p class="mt-1 text-sm font-medium text-gray-500 dark:text-gray-400">Production Components</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-gray-900 dark:text-white">10K+</p>
          <p class="mt-1 text-sm font-medium text-gray-500 dark:text-gray-400">Lines of TypeScript</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-gray-900 dark:text-white">250+</p>
          <p class="mt-1 text-sm font-medium text-gray-500 dark:text-gray-400">Design Tokens</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-bold text-gray-900 dark:text-white">100%</p>
          <p class="mt-1 text-sm font-medium text-gray-500 dark:text-gray-400">Test Coverage</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Features -->
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Built for scale. Designed for people.
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        Every decision in Storyhouse is made with one goal: make your team faster and your product more consistent.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        featureCards.map((card) => {
          const c = colorMaps[card.color];
          return (
            <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md dark:border-gray-800 dark:bg-gray-900">
              <div class={`mb-5 flex h-12 w-12 items-center justify-center rounded-lg ${c.bg}`}>
                <svg class={`h-6 w-6 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={card.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{card.title}</h3>
              <p class="mt-2 text-gray-600 dark:text-gray-400">{card.description}</p>
            </div>
          );
        })
      }
    </div>
  </div>

  <!-- Component Preview Grid -->
  <div class="border-t border-gray-200 bg-gray-50 py-20 dark:border-gray-800 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Components at a glance
        </h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          {miniCards.length} production-ready components, each with full documentation and interactive examples.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6">
        {
          miniCards.map((card) => {
            const mc = miniColorMaps[card.color];
            return (
              <a href={card.href} class="group block rounded-xl border border-gray-200 bg-white p-6 text-center shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
                <div class={`mx-auto flex h-10 w-10 items-center justify-center rounded-lg ${mc.bg}`}>
                  <svg class={`h-5 w-5 ${mc.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={card.icon} />
                  </svg>
                </div>
                <h3 class="mt-3 text-base font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">{card.title}</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">{card.description}</p>
              </a>
            );
          })
        }
      </div>

      <div class="mt-10 text-center">
        <a href={`${base}components`} class="inline-flex items-center font-semibold text-orange-600 hover:text-orange-700 dark:text-orange-400">
          View all components
          <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-orange-500 to-orange-700 px-8 py-16 text-center shadow-xl">
      <div class="relative z-10">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to build something great?</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-orange-100">
          Start using Storyhouse in your project today. Production-ready components, comprehensive tokens, and exceptional DX.
        </p>
        <div class="mt-8 flex items-center justify-center gap-4">
          <a
            href={`${base}guides/getting-started`}
            class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-orange-700 shadow-sm transition-all hover:bg-orange-50"
          >
            Get Started
          </a>
          <a
            href={`${base}storybook/`}
            class="inline-flex items-center justify-center rounded-lg border border-white/30 px-6 py-3 text-base font-semibold text-white transition-all hover:bg-white/10"
          >
            View Storybook
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
