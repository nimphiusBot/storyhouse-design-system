---
import DocLayout from '../../layouts/DocLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = `${base}components/breadcrumb`;
---

<DocLayout
  title="Breadcrumb"
  status="stable"
  description="Navigation breadcrumb component that displays the current page location within a hierarchy. Supports multiple variants, sizes, item limits, and optional icons."
  currentPath={currentPath}
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>Breadcrumb</code> component helps users understand their current location within a page hierarchy and navigate
      back to parent sections. It accepts an array of <code>BreadcrumbItem</code> objects with support for optional links, icons,
      and three visual variants: default (chevron separator), simple (slash separator), and arrow (right-arrow separator).
    </p>
  </section>

  <section>
    <h2 id="variants">Variants</h2>
    <p>Three visual variants control the separator style between breadcrumb items.</p>

    <div class="my-6 flex flex-col gap-4 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <div>
        <span class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">Default (Chevron)</span>
        <nav aria-label="Breadcrumb" class="flex items-center text-sm text-gray-600 dark:text-gray-400">
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
          <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Components</a>
          <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Breadcrumb</span>
        </nav>
      </div>
      <div>
        <span class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">Simple (Slash)</span>
        <nav aria-label="Breadcrumb" class="flex items-center text-sm text-gray-600 dark:text-gray-400">
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
          <span class="mx-2 text-gray-300 dark:text-gray-600">/</span>
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Components</a>
          <span class="mx-2 text-gray-300 dark:text-gray-600">/</span>
          <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Breadcrumb</span>
        </nav>
      </div>
      <div>
        <span class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">Arrow</span>
        <nav aria-label="Breadcrumb" class="flex items-center text-sm text-gray-600 dark:text-gray-400">
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
          <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5"/></svg>
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Components</a>
          <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5"/></svg>
          <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Breadcrumb</span>
        </nav>
      </div>
    </div>

    <CodeBlock title="breadcrumb-variants.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function BreadcrumbVariants() {
  const items = [
    { label: 'Home', href: '/' },
    { label: 'Components', href: '/components' },
    { label: 'Breadcrumb' },
  ];

  return (
    <div className="flex flex-col gap-4">
      <Breadcrumb variant="default" items={items} />
      <Breadcrumb variant="simple" items={items} />
      <Breadcrumb variant="arrow" items={items} />
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="sizes">Sizes</h2>
    <p>Three sizes are available — small for compact navigation headers, medium as the default, and large for page-level breadcrumbs.</p>

    <div class="my-6 flex flex-col gap-4 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <div>
        <span class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">Small</span>
        <nav aria-label="Breadcrumb" class="flex items-center text-xs text-gray-600 dark:text-gray-400">
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
          <svg class="mx-1.5 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Current</span>
        </nav>
      </div>
      <div>
        <span class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">Medium (Default)</span>
        <nav aria-label="Breadcrumb" class="flex items-center text-sm text-gray-600 dark:text-gray-400">
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
          <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Current</span>
        </nav>
      </div>
      <div>
        <span class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">Large</span>
        <nav aria-label="Breadcrumb" class="flex items-center text-base text-gray-600 dark:text-gray-400">
          <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
          <svg class="mx-2.5 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Current</span>
        </nav>
      </div>
    </div>

    <CodeBlock title="breadcrumb-sizes.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function BreadcrumbSizes() {
  const items = [
    { label: 'Home', href: '/' },
    { label: 'Current' },
  ];

  return (
    <div className="flex flex-col gap-4">
      <Breadcrumb size="sm" items={items} />
      <Breadcrumb size="md" items={items} />
      <Breadcrumb size="lg" items={items} />
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="icons">Items with Icons</h2>
    <p>Each breadcrumb item can include an optional icon rendered before the label. This is useful for file system navigators, admin dashboards, or category hierarchies.</p>

    <div class="my-6 flex rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <nav aria-label="Breadcrumb with icons" class="flex items-center text-sm text-gray-800 dark:text-gray-200">
        <a href="#" class="flex items-center text-blue-600 hover:text-blue-700 dark:text-blue-400">
          <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Home
        </a>
        <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="#" class="flex items-center text-blue-600 hover:text-blue-700 dark:text-blue-400">
          <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          Components
        </a>
        <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="flex items-center font-medium text-gray-900 dark:text-white" aria-current="page">
          <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Breadcrumb
        </span>
      </nav>
    </div>

    <CodeBlock title="breadcrumb-icons.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function BreadcrumbWithIcons() {
  const items = [
    { label: 'Home', href: '/', icon: <HomeIcon /> },
    { label: 'Components', href: '/components', icon: <BoxIcon /> },
    { label: 'Breadcrumb', icon: <FileIcon /> },
  ];

  return <Breadcrumb items={items} />;
}`} />
  </section>

  <section>
    <h2 id="max-items">Max Items (Collapsing)</h2>
    <p>
      Use <code>maxItems</code> to limit the number of visible breadcrumb items. When the item count exceeds the limit,
      intermediate items are collapsed into a single ellipsis indicator, keeping the navigation compact.
    </p>

    <div class="my-6 flex rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <nav aria-label="Breadcrumb with collapsed items" class="flex items-center text-sm text-gray-600 dark:text-gray-400">
        <a href="#" class="text-blue-600 hover:text-blue-700 dark:text-blue-400">Home</a>
        <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01"/></svg>
        <svg class="mx-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="font-medium text-gray-900 dark:text-white" aria-current="page">Current Page</span>
      </nav>
    </div>

    <CodeBlock title="breadcrumb-max-items.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function BreadcrumbMaxItems() {
  const items = [
    { label: 'Home', href: '/' },
    { label: 'Products', href: '/products' },
    { label: 'Electronics', href: '/products/electronics' },
    { label: 'Smartphones', href: '/products/electronics/smartphones' },
    { label: 'iPhone 15' },
  ];

  // Shows only first, last, and ellipsis for the middle items
  return <Breadcrumb items={items} maxItems={3} />;
}`} />
  </section>

  <section>
    <h2 id="props">Props</h2>
    <PropsTable
      rows={[
        { name: 'items', type: 'BreadcrumbItem[]', default: '-', description: 'Array of breadcrumb items defining the navigation hierarchy.' },
        { name: 'variant', type: '"default" | "simple" | "arrow"', default: '"default"', description: 'Visual separator style between items.' },
        { name: 'size', type: '"sm" | "md" | "lg"', default: '"md"', description: 'Controls font size and icon dimensions.' },
        { name: 'maxItems', type: 'number', default: '-', description: 'Maximum visible items before collapsing with an ellipsis. Use to keep long breadcrumbs compact.' },
        { name: 'className', type: 'string', default: '-', description: 'Additional CSS classes to merge with default styles.' },
      ]}
    />
    <h3 class="mt-6 text-lg font-semibold">BreadcrumbItem</h3>
    <PropsTable
      rows={[
        { name: 'label', type: 'string', default: '-', description: 'Display text for the breadcrumb item.' },
        { name: 'href', type: 'string', default: '-', description: 'Optional destination URL. When omitted, the item is rendered as plain text (indicating the current page).' },
        { name: 'icon', type: 'React.ReactNode', default: '-', description: 'Optional icon element rendered before the label.' },
      ]}
    />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases &amp; Error States</h2>

    <h3>Single Item</h3>
    <p>
      When only one item is provided, the breadcrumb renders as plain text without separators.
      This is useful for top-level pages that have no parent hierarchy.
    </p>

    <CodeBlock title="breadcrumb-single-item.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function SingleItemBreadcrumb() {
  const items = [{ label: 'Dashboard' }];
  return <Breadcrumb items={items} />;
}`} />

    <h3>Empty Items Array</h3>
    <p>
      An empty <code>items</code> array renders nothing. The component returns <code>null</code> rather than
      an empty <code>&lt;nav&gt;</code> element to avoid adding unnecessary landmarks to the accessibility tree.
    </p>

    <CodeBlock title="breadcrumb-empty.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function EmptyBreadcrumb() {
  return <Breadcrumb items={[]} />; // Renders null
}`} />

    <h3>All Items Non-Link (Last Item Already Current)</h3>
    <p>
      When every item has no <code>href</code>, the breadcrumb renders all items as plain text.
      In this case, you should ensure at least the last item has <code>aria-current="page"</code> set.
    </p>

    <CodeBlock title="breadcrumb-no-links.tsx" code={`import { Breadcrumb } from '@storyhouse/components';

export function NoLinksBreadcrumb() {
  const items = [
    { label: 'Category' },       // No href → plain text
    { label: 'Subcategory' },    // No href → plain text
    { label: 'Item Details' },   // Current page
  ];
  return <Breadcrumb items={items} />;
}`} />
  </section>

  <section>
    <h2 id="best-practices">Best Practices &amp; Usage Guidelines</h2>
    <ul>
      <li><strong>Start from the top</strong> — Begin breadcrumbs from the highest-level page (e.g., "Home") down to the current page.</li>
      <li><strong>Don't include the current page as a link</strong> — The last item should be plain text with <code>aria-current="page"</code> to indicate the user's current location.</li>
      <li><strong>Use maxItems for deep hierarchies</strong> — For deeply nested paths (5+ levels), set <code>maxItems</code> to keep the breadcrumb visually compact.</li>
      <li><strong>Match page title</strong> — The last breadcrumb item should match the page's <code>&lt;h1&gt;</code> heading for consistency.</li>
      <li><strong>Place above the page title</strong> — Position breadcrumbs above the page heading, typically in the page header region.</li>
      <li><strong>Keep labels short</strong> — Use concise labels. Long labels can wrap awkwardly; consider truncation via CSS if needed.</li>
    </ul>
  </section>

  <section>
    <h2 id="implementation">Implementation Details</h2>

    <h3>Separator Rendering</h3>
    <p>
      Each variant renders a different separator element between consecutive items:
      <em>default</em> uses a chevron icon (<code>&gt;</code>), <em>simple</em> uses a slash (<code>/</code>),
      and <em>arrow</em> uses a right-arrow icon. Separators are not rendered before the first item.
    </p>

    <h3>Last Item Styling</h3>
    <p>
      The last item in the <code>items</code> array is automatically styled as the current page —
      it has <code>font-medium</code> weight, <code>text-gray-900</code> (or <code>text-white</code> in dark mode),
      and <code>aria-current="page"</code> for accessibility. Even if <code>href</code> is provided, the last item
      will not render as a link; always omit <code>href</code> on the final item.
    </p>

    <h3>Collapsing Logic</h3>
    <p>
      When <code>maxItems</code> is set and the item count exceeds it, the middle items are collapsed.
      The first item and the last item are always visible. The collapsed items are replaced by an ellipsis indicator
      that can be clicked (or hovered) to reveal the full path in a tooltip or popover in future versions.
    </p>

    <h3>Dark Mode</h3>
    <p>
      All separator colors, link colors, and text colors use Tailwind dark-mode variants so the breadcrumb
      automatically adapts when the page switches to dark mode.
    </p>
  </section>

  <section>
    <h2 id="accessibility">Accessibility</h2>
    <ul>
      <li>Uses a <code>&lt;nav&gt;</code> landmark element with <code>aria-label="Breadcrumb"</code></li>
      <li>Last item has <code>aria-current="page"</code> to indicate the current location</li>
      <li>Link items have proper <code>href</code> attributes for keyboard and screen reader navigation</li>
      <li>Separators are decorative and hidden from screen readers (<code>aria-hidden="true"</code>)</li>
      <li>Icons within items are decorative and not announced by screen readers</li>
      <li>Color contrast meets WCAG AA standards for all link and text colors</li>
    </ul>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <p>Explore all Breadcrumb variants and props interactively in Storybook:</p>
    <StorybookPreview id="components-breadcrumb--default" title="Breadcrumb — Storybook" height="500" />
  </section>
</DocLayout>
