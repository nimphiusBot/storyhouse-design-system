---
import DocLayout from '../../layouts/DocLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';
import LiveBadgeDemo from '../../components/react/LiveBadgeDemo';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = `${base}components/badge`;
---

<DocLayout
  title="Badge"
  status="stable"
  description="Small status indicators for counts, labels, tags, and states. Supports variants, sizes, dot indicators, and removable tags."
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>Badge</code> component is used for status indicators, labels, tags, counts, and other small
      pieces of metadata. It supports six color variants, two sizes, a dot indicator mode, and removable
      tag functionality. Badges are fully accessible with proper ARIA attributes.
    </p>
  </section>

  <section>
    <h2 id="live-demo">Live Demo</h2>
    <p>Interact with the Badge component — try clicking the X buttons on removable tags.</p>
    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <LiveBadgeDemo client:load />
    </div>
  </section>

  <section>
    <h2 id="variants">Variants</h2>
    <p>Six visual variants map to different semantic meanings.</p>

    <div class="my-6 flex flex-wrap items-center gap-2 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-2.5 py-1 text-sm font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">Default</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-2.5 py-1 text-sm font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-300">Primary</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-2.5 py-1 text-sm font-medium text-green-700 dark:bg-green-950 dark:text-green-300">Success</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-yellow-100 px-2.5 py-1 text-sm font-medium text-yellow-700 dark:bg-yellow-950 dark:text-yellow-300">Warning</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 px-2.5 py-1 text-sm font-medium text-red-700 dark:bg-red-950 dark:text-red-300">Danger</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-2.5 py-1 text-sm font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Neutral</span>
    </div>

    <CodeBlock title="badge-variants.tsx" code={`import { Badge } from '@storyhouse/components';

export function BadgeVariants() {
  return (
    <div className="flex flex-wrap gap-2">
      <Badge variant="default">Default</Badge>
      <Badge variant="primary">Primary</Badge>
      <Badge variant="success">Success</Badge>
      <Badge variant="warning">Warning</Badge>
      <Badge variant="danger">Danger</Badge>
      <Badge variant="neutral">Neutral</Badge>
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="sizes">Sizes</h2>

    <div class="my-6 flex flex-wrap items-center gap-2 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-300">Small</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-2.5 py-1 text-sm font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-300">Medium</span>
    </div>

    <CodeBlock title="badge-sizes.tsx" code={`import { Badge } from '@storyhouse/components';

export function BadgeSizes() {
  return (
    <div className="flex flex-wrap gap-2">
      <Badge size="sm">Small</Badge>
      <Badge size="md">Medium</Badge>
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="dot-indicator">Dot Indicator</h2>
    <p>Add <code>dot</code> to show a small colored circle before the text — useful for live status indicators.</p>

    <div class="my-6 flex flex-wrap items-center gap-2 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-2.5 py-1 text-sm font-medium text-green-700 dark:bg-green-950 dark:text-green-300"><span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>Online</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-yellow-100 px-2.5 py-1 text-sm font-medium text-yellow-700 dark:bg-yellow-950 dark:text-yellow-300"><span class="h-1.5 w-1.5 rounded-full bg-yellow-500"></span>Away</span>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 px-2.5 py-1 text-sm font-medium text-red-700 dark:bg-red-950 dark:text-red-300"><span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>Offline</span>
    </div>

    <CodeBlock title="badge-dot.tsx" code={`import { Badge } from '@storyhouse/components';

export function BadgeDot() {
  return (
    <div className="flex flex-wrap gap-2">
      <Badge variant="success" dot>Online</Badge>
      <Badge variant="warning" dot>Away</Badge>
      <Badge variant="danger" dot>Offline</Badge>
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="removable">Removable Tags</h2>
    <p>Use <code>removable</code> with an <code>onRemove</code> callback for tag-like badges that can be dismissed.</p>

    <CodeBlock title="badge-removable.tsx" code={`import { Badge } from '@storyhouse/components';

export function BadgeRemovable() {
  const [tags, setTags] = React.useState(['React', 'TypeScript', 'Design']);

  return (
    <div className="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <Badge
          key={tag}
          variant="primary"
          removable
          onRemove={() => setTags((prev) => prev.filter((t) => t !== tag))}
        >
          {tag}
        </Badge>
      ))}
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases &amp; Error States</h2>

    <h3>Very Long Badge Text</h3>
    <p>
      Badges do not wrap text. Long content will stretch the badge horizontally. For text longer than
      20 characters, consider using a different UI treatment or truncating via <code>className</code>
      with <code>max-w-[160px] truncate</code>.
    </p>

    <CodeBlock title="badge-truncated.tsx" code={`import { Badge } from '@storyhouse/components';

export function BadgeTruncated() {
  return (
    <Badge className="max-w-[160px] truncate">
      Very long badge text that should be truncated
    </Badge>
  );
}`} />

    <h3>Multiple Removable Badges — Keyboard Navigation</h3>
    <p>
      Each removable badge has an X button that is a focusable <code>&lt;button&gt;</code> element.
      Users can Tab through multiple remove buttons. The remove button has <code>aria-label="Remove"</code>
      for screen reader clarity. Ensure <code>onRemove</code> handlers manage focus correctly —
      move focus to the next remaining badge after removal.
    </p>

    <h3>Small Size with Dot</h3>
    <p>
      The dot indicator works in both <code>sm</code> and <code>md</code> sizes. The dot remains the
      same 6px diameter regardless of badge size, which keeps it visually consistent across sizes.
    </p>

    <h3>Accessibility of Dynamic Badges</h3>
    <p>
      When badges represent dynamic content (e.g., live status updates), consider wrapping the container
      with <code>aria-live="polite"</code> or <code>role="status"</code> so screen readers announce
      changes. Badges themselves don't have built-in live region support because they don't know the
      context in which they're used.
    </p>
  </section>

  <section>
    <h2 id="best-practices">Best Practices &amp; Usage Guidelines</h2>

    <h3>Semantic Variant Selection</h3>
    <ul>
      <li><strong>Default</strong> — Generic labels with no semantic association</li>
      <li><strong>Primary</strong> — Feature flags, category labels, selected states</li>
      <li><strong>Success</strong> — Completed actions, active status, available resources</li>
      <li><strong>Warning</strong> — Pending actions, expiring items, moderate issues</li>
      <li><strong>Danger</strong> — Errors, blocked states, failed actions</li>
      <li><strong>Neutral</strong> — Counts, metadata, secondary information</li>
    </ul>

    <h3>When to Use Dot</h3>
    <p>
      The <code>dot</code> prop is ideal for real-time status indicators: online/offline presence,
      live/unprocessed notifications, active/inactive states. The dot color always matches the variant
      color for visual coherence. Do not use the dot for static labels — it implies liveness.
    </p>

    <h3>Layout Considerations</h3>
    <ul>
      <li>Use <code>flex flex-wrap gap-2</code> for badge groups — badges wrap naturally on small screens</li>
      <li>Avoid more than 6-8 badges in a single row — visual overload</li>
      <li>Place badges near the content they annotate (after titles, next to metrics)</li>
      <li>Removable badges should have an accessible remove confirmation if the action is destructive</li>
      <li>Use <code>sm</code> size inside dense data tables and list items</li>
    </ul>

    <h3>Accessibility</h3>
    <ul>
      <li>Badge text is directly readable by assistive technology — no ARIA hiding needed</li>
      <li>Remove button has <code>aria-label="Remove"</code> — screen readers announce it clearly</li>
      <li>Dot indicator uses <code>aria-hidden="true"</code> to prevent screen reader distraction</li>
      <li>All color variants maintain WCAG AA contrast (verified against white backgrounds)</li>
      <li>Color is not the only indicator of meaning — always pair with text</li>
    </ul>
  </section>

  <section>
    <h2 id="implementation">Implementation Details</h2>

    <h3>Dot Color Architecture</h3>
    <p>
      The dot indicator color is determined by a <code>dotColors</code> map that mirrors the
      <code>variantStyles</code> map. This ensures the dot always matches the badge text color
      scheme. The dot is rendered as a 6px rounded span with <code>aria-hidden="true"</code>.
    </p>

    <h3>Removable Button Integration</h3>
    <p>
      The remove button is a native <code>&lt;button&gt;</code> element inside the badge span,
      making it keyboard-focusable. It uses a small inline SVG X icon and a hover state with
      semi-transparent background (<code>hover:bg-black/5</code>). The <code>onRemove</code> callback
      fires on click — the component does not manage its own state.
    </p>

    <h3>Dark Mode</h3>
    <p>
      All variant background colors have dark mode counterparts via the <code>dark:</code> prefix.
      For example, <code>bg-green-100</code> becomes <code>dark:bg-green-950</code>. Text colors
      shift from bright to <code>-300</code> shade for readability on dark backgrounds.
    </p>
  </section>

  <section>
    <h2 id="props">Props</h2>
    <PropsTable
      rows={[
        { name: 'variant', type: '"default" | "primary" | "success" | "warning" | "danger" | "neutral"', default: '"default"', description: 'Semantic color variant for different contexts.' },
        { name: 'size', type: '"sm" | "md"', default: '"md"', description: 'Badge size. Use sm for compact layouts.' },
        { name: 'dot', type: 'boolean', default: 'false', description: 'Shows a small colored circle indicator before the text.' },
        { name: 'removable', type: 'boolean', default: 'false', description: 'Shows an X button for dismissing the badge.' },
        { name: 'onRemove', type: '() => void', default: '-', description: 'Callback fired when the remove button is clicked.' },
        { name: 'children', type: 'React.ReactNode', default: '-', description: 'Content inside the badge.' },
        { name: 'className', type: 'string', default: '-', description: 'Additional CSS classes.' },
      ]}
    />
  </section>

  <section>
    <h2 id="accessibility">Accessibility</h2>
    <ul>
      <li>Remove button has <code>aria-label="Remove"</code> for screen readers</li>
      <li>Dot indicator uses <code>aria-hidden="true"</code> to prevent screen reader distraction</li>
      <li>Badge text is directly readable by assistive technology</li>
      <li>Color variants maintain sufficient contrast ratio (all pass WCAG AA)</li>
    </ul>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <p>Explore all Badge variants and props interactively in Storybook:</p>
    <StorybookPreview id="components-badge--default" title="Badge — Storybook" height="500" />
  </section>
</DocLayout>
