---
import DocLayout from '../../layouts/DocLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';
import LiveFormatSelectDemo from '../../components/react/LiveFormatSelectDemo';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = base + 'components/format-select';
---

<DocLayout
  title="FormatSelect"
  status="stable"
  description="A rich custom select dropdown using Radix UI for displaying format options with descriptions, badges, and metadata."
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>FormatSelect</code> component provides a beautiful, accessible custom dropdown for selecting content
      formats. Each option displays rich metadata (sources count, aspect ratio, generation model, descriptions)
      alongside the format name and an emoji. Built on <code>@radix-ui/react-select</code> for accessibility and
      keyboard navigation.
    </p>
  </section>

  <section>
    <h2 id="live-demo">Live Demo</h2>
    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <LiveFormatSelectDemo client:load />
    </div>
  </section>

  <section>
    <h2 id="props">Props</h2>
    <PropsTable
      rows={[
        { name: 'options', type: 'FormatOption[]', default: '-', description: 'Array of format options with metadata.' },
        { name: 'value', type: 'string', default: '-', description: 'Currently selected format value.' },
        { name: 'onChange', type: '(value: string) => void', default: '-', description: 'Callback when selection changes.' },
        { name: 'placeholder', type: 'string', default: "'Select a format...'", description: 'Placeholder text when no value is selected.' },
        { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the select.' },
        { name: 'className', type: 'string', default: '-', description: 'Additional CSS classes.' },
      ]}
    />
  </section>

  <section>
    <h2 id="types">FormatOption</h2>
    <PropsTable
      rows={[
        { name: 'format', type: 'string', default: '-', description: 'Format name (e.g., "YouTube Short").' },
        { name: 'intent', type: 'string', default: '-', description: 'Short description of the format purpose.' },
        { name: 'emoji', type: 'string', default: '-', description: 'Optional emoji icon for the format.' },
        { name: 'description', type: 'string', default: '-', description: 'Optional detailed description.' },
        { name: 'sources', type: 'any[]', default: '-', description: 'Source/dataset references.' },
        { name: 'defaultAspectRatio', type: 'string', default: '-', description: 'Default aspect ratio (e.g., "16:9").' },
        { name: 'generationModel', type: 'string', default: '-', description: 'AI model used for generation.' },
      ]}
    />
  </section>

  <section>
    <h2 id="usage">Usage</h2>
    <CodeBlock title="format-select-basic.tsx" code={`import { FormatSelect, type FormatOption } from '@storyhouse/components';

const options: FormatOption[] = [
  {
    format: 'YouTube Short',
    intent: 'Short-form video content',
    emoji: '📱',
    sources: [],
    defaultAspectRatio: '9:16',
  },
  {
    format: 'Blog Article',
    intent: 'Long-form written content',
    emoji: '📝',
    sources: [{ name: 'Docs' }],
  },
];

export function FormatPicker() {
  const [format, setFormat] = React.useState('');

  return (
    <FormatSelect
      options={options}
      value={format}
      onChange={setFormat}
    />
  );
}`} />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases</h2>
    <h3>No Selection</h3>
    <p>When value is empty string, the placeholder is shown.</p>

    <h3>Disabled State</h3>
    <p>When disabled, the trigger appears with reduced opacity and interaction is prevented.</p>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <p>Explore in Storybook:</p>
    <StorybookPreview id="components-formatselect--default" title="FormatSelect — Storybook" height="400" />
  </section>
</DocLayout>
