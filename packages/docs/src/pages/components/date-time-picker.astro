---
import DocLayout from '../../layouts/DocLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';
import LiveDateTimePickerDemo from '../../components/react/LiveDateTimePickerDemo';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = base + 'components/date-time-picker';
---

<DocLayout
  title="DateTimePicker"
  status="stable"
  description="A flexible date and time picker component supporting date-only, time-only, and combined date-time selection modes with clearable inputs and validation states."
  currentPath={currentPath}
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>DateTimePicker</code> component provides a native browser-based date/time picker with three modes:
      date-only, time-only, and combined datetime. It includes label support, error/success/help text states,
      size variants, clearable inputs, and min/max constraints.
    </p>
  </section>

  <section>
    <h2 id="live-demo">Live Demo</h2>
    <p>Interact with the DateTimePicker in different modes and states below.</p>
    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <LiveDateTimePickerDemo client:load />
    </div>
  </section>

  <section>
    <h2 id="modes">Modes</h2>
    <p>The component supports three modes via the <code>mode</code> prop:</p>
    <ul>
      <li><strong>date</strong> — Shows a date picker calendar (input type="date")</li>
      <li><strong>time</strong> — Shows a time picker (input type="time")</li>
      <li><strong>datetime</strong> — Shows combined date and time picker (input type="datetime-local")</li>
    </ul>
  </section>

  <section>
    <h2 id="props">Props</h2>
    <PropsTable
      rows={[
        { name: 'label', type: 'string', default: '-', description: 'Label text displayed above the input.' },
        { name: 'error', type: 'string', default: '-', description: 'Error message (also sets variant to error).' },
        { name: 'helpText', type: 'string', default: '-', description: 'Help text displayed below the input.' },
        { name: 'mode', type: '"date" | "time" | "datetime"', default: '"date"', description: 'Picker mode for date, time, or combined.' },
        { name: 'value', type: 'string | Date | null', default: '-', description: 'Current value of the picker.' },
        { name: 'onChange', type: '(value: string | null) => void', default: '-', description: 'Callback when value changes.' },
        { name: 'variant', type: '"default" | "filled" | "error" | "success"', default: '"default"', description: 'Visual variant of the input.' },
        { name: 'size', type: '"sm" | "md" | "lg"', default: '"md"', description: 'Size of the input element.' },
        { name: 'clearable', type: 'boolean', default: 'true', description: 'Show a clear button when a value is selected.' },
        { name: 'showIcon', type: 'boolean', default: 'true', description: 'Show a calendar/clock icon inside the input.' },
        { name: 'min', type: 'string | Date', default: '-', description: 'Minimum selectable date.' },
        { name: 'max', type: 'string | Date', default: '-', description: 'Maximum selectable date.' },
        { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the input.' },
        { name: 'required', type: 'boolean', default: 'false', description: 'Marks the input as required.' },
      ]}
    />
  </section>

  <section>
    <h2 id="date-range-picker">DateRangePicker</h2>
    <p>
      The <code>DateRangePicker</code> composes two <code>DateTimePicker</code> instances to create a start/end date
      range selector. The end date enforces a minimum equal to the start date, and the start date enforces a maximum
      equal to the end date.
    </p>

    <CodeBlock title="date-range-picker.tsx" code={`import { DateRangePicker } from '@storyhouse/components';

export function DateRangeExample() {
  const [startDate, setStartDate] = React.useState<string | null>(null);
  const [endDate, setEndDate] = React.useState<string | null>(null);

  return (
    <DateRangePicker
      startLabel="Start Date"
      endLabel="End Date"
      startValue={startDate}
      endValue={endDate}
      onStartChange={setStartDate}
      onEndChange={setEndDate}
    />
  );
}`} />
  </section>

  <section>
    <h2 id="usage">Usage</h2>
    <CodeBlock title="date-time-picker-basic.tsx" code={`import { DateTimePicker } from '@storyhouse/components';

export function BasicDatePicker() {
  const [date, setDate] = React.useState<string | null>(null);

  return (
    <DateTimePicker
      label="Event Date"
      mode="date"
      value={date}
      onChange={setDate}
    />
  );
}

export function TimePicker() {
  const [time, setTime] = React.useState<string | null>(null);

  return (
    <DateTimePicker
      label="Start Time"
      mode="time"
      value={time}
      onChange={setTime}
    />
  );
}

export function DateTimePickerExample() {
  const [datetime, setDatetime] = React.useState<string | null>(null);

  return (
    <DateTimePicker
      label="Appointment"
      mode="datetime"
      value={datetime}
      onChange={setDatetime}
    />
  );
}`} />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases &amp; Error States</h2>
    <h3>Empty Value</h3>
    <p>When <code>value</code> is <code>null</code> or <code>undefined</code>, the input shows a placeholder empty state.</p>

    <h3>Invalid Date Handling</h3>
    <p>If an invalid date string is passed as <code>value</code>, the <code>new Date(value)</code> call will fall back gracefully. Always pass valid ISO 8601 strings or Date objects.</p>

    <h3>Clearable Behavior</h3>
    <p>When <code>clearable</code> is enabled (default), an X button appears on the right side of the input when a value is selected. Clicking it resets the value to <code>null</code> via the <code>onChange</code> callback.</p>

    <h3>Disabled With Value</h3>
    <p>When <code>disabled</code> is true but a value is set, the input shows the value in a disabled (reduced opacity) state without the clear button.</p>
  </section>

  <section>
    <h2 id="implementation">Implementation Details</h2>
    <p>
      The component uses native HTML5 input types (<code>date</code>, <code>time</code>, <code>datetime-local</code>)
      for native browser date picker support. The <code>value</code> is converted internally to the appropriate format
      for the input type, and changes are emitted as ISO 8601 strings.
    </p>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <p>Explore all variants and props interactively in Storybook:</p>
    <StorybookPreview id="components-date-time-picker--date" title="DateTimePicker — Storybook" height="500" />
  </section>
</DocLayout>
