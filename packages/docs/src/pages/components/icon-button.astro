---
import DocLayout from '../../layouts/DocLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = `${base}components/icon-button`;
---

<DocLayout
  title="IconButton"
  status="stable"
  description="Compact icon-only button for toolbars, actions, and compact interfaces. Three variants, three colors, three sizes, with loading state."
  currentPath={currentPath}
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>IconButton</code> component provides a compact button sized for icons. It supports three
      visual variants (<code>solid</code>, <code>outline</code>, <code>ghost</code>), three semantic
      colors (<code>default</code>, <code>primary</code>, <code>danger</code>), and three sizes.
      A loading spinner state is built in. <code>aria-label</code> is required for accessibility.
    </p>
  </section>

  <section>
    <h2 id="variants">Variants &amp; Colors</h2>

    <div class="my-6 space-y-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <div>
        <p class="mb-3 text-sm font-semibold text-gray-500 uppercase">Solid</p>
        <div class="flex flex-wrap gap-3">
          <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors dark:bg-gray-800 dark:text-gray-300"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
        </div>
      </div>
      <div>
        <p class="mb-3 text-sm font-semibold text-gray-500 uppercase">Outline</p>
        <div class="flex flex-wrap gap-3">
          <button class="flex h-10 w-10 items-center justify-center rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors dark:border-gray-600 dark:text-gray-300"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg border border-blue-500 text-blue-600 hover:bg-blue-50 transition-colors"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg border border-red-500 text-red-600 hover:bg-red-50 transition-colors"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
        </div>
      </div>
      <div>
        <p class="mb-3 text-sm font-semibold text-gray-500 uppercase">Ghost</p>
        <div class="flex flex-wrap gap-3">
          <button class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 transition-colors dark:text-gray-400"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg text-blue-600 hover:bg-blue-50 transition-colors"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg text-red-600 hover:bg-red-50 transition-colors"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
        </div>
      </div>
    </div>

    <CodeBlock title="icon-button-variants.tsx" code={`import { IconButton } from '@storyhouse/components';

export function IconButtonVariants() {
  return (
    <div className="flex flex-wrap gap-3">
      <IconButton variant="solid" color="default" aria-label="Arrow right" icon={<ArrowRight />} />
      <IconButton variant="solid" color="primary" aria-label="Arrow right" icon={<ArrowRight />} />
      <IconButton variant="solid" color="danger" aria-label="Delete" icon={<Trash />} />
      <IconButton variant="outline" color="primary" aria-label="Edit" icon={<Edit />} />
      <IconButton variant="ghost" color="default" aria-label="Settings" icon={<Settings />} />
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="loading">Loading State</h2>
    <p>Set <code>isLoading</code> to show a spinner instead of the icon. The button is disabled during loading.</p>

    <div class="my-6 flex flex-wrap gap-3 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-600 text-white" disabled>
        <svg class="h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
      </button>
      <button class="flex h-10 w-10 items-center justify-center rounded-lg border border-blue-500 text-blue-600" disabled>
        <svg class="h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
      </button>
    </div>

    <CodeBlock title="icon-button-loading.tsx" code={`import { IconButton } from '@storyhouse/components';
import { Save } from 'lucide-react';

export function LoadingIconButton() {
  const [loading, setLoading] = React.useState(false);

  const handleSave = () => {
    setLoading(true);
    setTimeout(() => setLoading(false), 2000);
  };

  return (
    <IconButton
      variant="solid"
      color="primary"
      aria-label="Save"
      icon={<Save />}
      isLoading={loading}
      onClick={handleSave}
    />
  );
}`} />
  </section>

  <section>
    <h2 id="props">Props</h2>
    <PropsTable
      rows={[
        { name: 'aria-label', type: 'string', default: '(required)', description: 'Accessible label for screen readers. Always required.' },
        { name: 'size', type: '"sm" | "md" | "lg"', default: '"md"', description: 'Controls the button dimensions and icon size.' },
        { name: 'variant', type: '"solid" | "outline" | "ghost"', default: '"ghost"', description: 'Visual style of the button.' },
        { name: 'color', type: '"default" | "primary" | "danger"', default: '"default"', description: 'Semantic color scheme.' },
        { name: 'icon', type: 'ReactNode', default: '(required)', description: 'Icon element to display.' },
        { name: 'isLoading', type: 'boolean', default: 'false', description: 'Shows a spinner and disables the button.' },
        { name: 'className', type: 'string', default: '-', description: 'Additional CSS classes merged via tailwind-merge.' },
        { name: '...props', type: 'ButtonHTMLAttributes', default: '-', description: 'All native button HTML attributes are forwarded.' },
      ]}
    />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases &amp; Best Practices</h2>

    <h3>Missing aria-label</h3>
    <p><code>aria-label</code> is required for every IconButton since there is no visible text. TypeScript will enforce this at build time.</p>

    <h3>Icon + Loading</h3>
    <p>When <code>isLoading</code> is true, the icon is replaced by a spinner. The button is also disabled to prevent double-clicks.</p>

    <h3>Tooltip</h3>
    <p>Always pair IconButton with a Tooltip for discoverability. Without visible labels, users need hover text to understand the action.</p>

    <CodeBlock title="icon-button-with-tooltip.tsx" code={`import { IconButton, Tooltip } from '@storyhouse/components';
import { Trash } from 'lucide-react';

export function DeleteButton() {
  return (
    <Tooltip content="Delete item">
      <IconButton
        variant="outline"
        color="danger"
        aria-label="Delete item"
        icon={<Trash />}
      />
    </Tooltip>
  );
}`} />
  </section>

  <section>
    <h2 id="implementation">Implementation Details</h2>
    <p>
      IconButton uses <code>class-variance-authority</code> with compound variants for
      variant × color combinations. The loading state renders a <code>Loader2</code> spinner
      from <code>lucide-react</code> with <code>animate-spin</code>. The component forwards
      all native button props via <code>React.forwardRef</code>.
    </p>
  </section>

  <section>
    <h2 id="accessibility">Accessibility</h2>
    <ul>
      <li><code>aria-label</code> is required — TypeScript enforces this</li>
      <li>Native <code>button</code> element with keyboard navigation</li>
      <li>Disabled state during loading prevents keyboard activation</li>
      <li>Focus-visible ring for keyboard users</li>
      <li>Spinner has <code>aria-hidden="true"</code></li>
    </ul>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <StorybookPreview id="components-iconbutton--ghost-default" title="IconButton — Storybook" height="500" />
  </section>
</DocLayout>
