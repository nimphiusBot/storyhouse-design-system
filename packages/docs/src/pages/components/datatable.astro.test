---
import DocLayout from '../../layouts/DocLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';
import LiveDataTableDemo from '../../components/react/LiveDataTableDemo';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = base + 'components/datatable';

const githubUrl = 'https://github.com/nimphiusBot/storyhouse-design-system/tree/main/packages/components/src/components/DataTable';
const storybookUrl = '/storyhouse-design-system/storybook/?path=/docs-components-datatable--docs';

const props = [
  { name: 'data', type: 'T[]', default: '-', description: 'Array of data items to display' },
  { name: 'columns', type: 'Column<T>[]', default: '-', description: 'Column definitions with key, label, render, sortable' },
  { name: 'keyExtractor', type: '(item: T, index: number) => string | number', default: 'index', description: 'Function to extract a unique key from each row' },
  { name: 'selectable', type: 'boolean', default: 'false', description: 'Enables row selection checkboxes' },
  { name: 'selectedRows', type: 'Set<string | number>', default: '-', description: 'Controlled selected row keys' },
  { name: 'onSelectionChange', type: '(selected: Set<string | number>) => void', default: '-', description: 'Callback when selection changes' },
  { name: 'sortable', type: 'boolean', default: 'false', description: 'Enables column sorting' },
  { name: 'defaultSortKey', type: 'string', default: '-', description: 'Default column key to sort by on mount' },
  { name: 'defaultSortDirection', type: '"asc" | "desc"', default: '"asc"', description: 'Default sort direction' },
  { name: 'onSort', type: '(key: string, direction: "asc" | "desc") => void', default: '-', description: 'Callback when sort changes' },
  { name: 'striped', type: 'boolean', default: 'false', description: 'Alternates row background colors (zebra striping)' },
  { name: 'bordered', type: 'boolean', default: 'false', description: 'Adds border around the table' },
  { name: 'hoverable', type: 'boolean', default: 'true', description: 'Highlights rows on hover' },
  { name: 'dense', type: 'boolean', default: 'false', description: 'Compact padding for high-density data' },
  { name: 'stickyHeader', type: 'boolean', default: 'false', description: 'Keeps the header fixed when scrolling vertically' },
  { name: 'loading', type: 'boolean', default: 'false', description: 'Shows loading state with spinner' },
  { name: 'empty', type: '{ icon?: ReactNode; title?: string; description?: string }', default: '-', description: 'Empty state configuration' },
  { name: 'expandable', type: 'boolean', default: 'false', description: 'Enables expandable rows' },
  { name: 'renderExpandedRow', type: '(row: T) => ReactNode', default: '-', description: 'Renders expanded row content' },
  { name: 'onRowClick', type: '(item: T) => void', default: '-', description: 'Callback when a row is clicked' },
  { name: 'className', type: 'string', default: '-', description: 'Additional CSS class names' },
];

const columnProps = [
  { name: 'key', type: 'string', default: '-', description: 'Data key for the column' },
  { name: 'label', type: 'string', default: '-', description: 'Column header label' },
  { name: 'sortable', type: 'boolean', default: 'false', description: 'Makes the column sortable' },
  { name: 'sortKey', type: 'string', default: '-', description: 'Custom sort key if different from column key' },
  { name: 'render', type: '(row: T, index: number) => ReactNode', default: '-', description: 'Custom cell renderer' },
  { name: 'align', type: '"left" | "center" | "right"', default: '"left"', description: 'Text alignment for the column' },
  { name: 'width', type: 'string', default: '-', description: 'CSS width for the column (e.g. "100px", "20%")' },
];
---

<DocLayout
  title="DataTable"
  currentPath={currentPath}
  description="A data table component for displaying structured data with sorting, selection, expandable rows, and custom cell rendering."
>
  <div class="space-y-12">
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">DataTable</h1>
        <StatusBadge status="stable" />
      </div>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        A feature-rich data table component with sorting, row selection, expandable rows,
        striped/bordered/hoverable/dense variants, loading skeleton, empty state, sticky headers,
        and custom cell rendering.
      </p>
      <div class="flex items-center gap-4">
        <a href={githubUrl} class="text-sm text-orange-600 hover:text-orange-700 dark:text-orange-400">
          View Source →
        </a>
        <a href={storybookUrl} class="text-sm text-orange-600 hover:text-orange-700 dark:text-orange-400">
          View Storybook →
        </a>
      </div>
    </div>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Live Demo</h2>
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 overflow-x-auto">
        <LiveDataTableDemo client:load />
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Sorting</p>
          <p class="text-sm text-gray-500">Click column headers to sort ascending/descending. Programmatic sort control via <code>defaultSortKey</code> and <code>onSort</code>.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Row Selection</p>
          <p class="text-sm text-gray-500">Checkbox-based row selection with "select all" header and indeterminate state for partial selection.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Expandable Rows</p>
          <p class="text-sm text-gray-500">Click to expand rows with custom detail content rendered by <code>renderExpandedRow</code>.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Striped / Bordered / Hoverable</p>
          <p class="text-sm text-gray-500">Three visual variants: <code>striped</code> for zebra rows, <code>bordered</code> for outlined table, <code>hoverable</code> for row highlight on hover.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Dense Mode</p>
          <p class="text-sm text-gray-500">Compact padding via <code>dense</code> prop for high-density data views.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Sticky Header</p>
          <p class="text-sm text-gray-500">Keep headers fixed during vertical scroll with <code>stickyHeader</code> prop.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Loading</p>
          <p class="text-sm text-gray-500">Animated spinner and status message when <code>loading</code> is set.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Empty State</p>
          <p class="text-sm text-gray-500">Customizable empty state with icon, title, and description when no data is available.</p>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-medium text-gray-900 dark:text-white mb-2">Custom Cell Rendering</p>
          <p class="text-sm text-gray-500">Each column accepts a <code>render</code> function for custom cell content, alignment, and width control.</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Variants</h2>
      <div class="space-y-4">
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-semibold text-gray-900 dark:text-white mb-3">Visual Variants</p>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div><code class="text-orange-600 font-medium">striped</code> — Zebra-striped rows for easier scanning.</div>
            <div><code class="text-orange-600 font-medium">bordered</code> — Adds a border around the entire table.</div>
            <div><code class="text-orange-600 font-medium">hoverable</code> — Highlights row on hover (enabled by default).</div>
            <div><code class="text-orange-600 font-medium">dense</code> — Reduces cell padding for high-density data.</div>
            <div><code class="text-orange-600 font-medium">stickyHeader</code> — Fixes header during vertical scroll.</div>
          </div>
        </div>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <p class="font-semibold text-gray-900 dark:text-white mb-3">Behavioral Variants</p>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div><code class="text-orange-600 font-medium">sortable</code> — Enable column sorting via header clicks.</div>
            <div><code class="text-orange-600 font-medium">selectable</code> — Add row selection checkboxes.</div>
            <div><code class="text-orange-600 font-medium">expandable</code> — Enable expandable rows with custom content.</div>
            <div><code class="text-orange-600 font-medium">loading</code> — Show loading spinner overlay.</div>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 id="props" class="text-2xl font-bold text-gray-900 dark:text-white mb-4">API</h2>
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2">DataTable Props</h3>
      <PropsTable rows={props} />
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mt-6 mb-2">Column Props</h3>
      <PropsTable rows={columnProps} />
    </section>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Usage</h2>
      
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-2">Basic</h3>
      <CodeBlock lang="tsx" code={`// code omitted for testing`} />
      
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mt-8 mb-2">Advanced</h3>
      <CodeBlock lang="tsx" code={`import { DataTable } from '@storyhouse/components';
import type { Column } from '@storyhouse/components';

interface User {
  id: number;
  name: string;
  email: string;
  role: string;
}

const columns: Column<User>[] = [
  { key: 'name', label: 'Name', sortable: true },
  { key: 'email', label: 'Email', sortable: true },
  { key: 'role', label: 'Role' },
  {
    key: 'actions',
    label: 'Actions',
    align: 'right',
    render: (user) => <button onClick={() => edit(user.id)}>Edit</button>,
  },
];

export function UsersTable({ data }: { data: User[] }) {
  const [selected, setSelected] = useState<Set<string | number>>(new Set());
  const [sortKey, setSortKey] = useState<string>('name');
  const [sortDir, setSortDir] = useState<'asc' | 'desc'>('asc');

  return (
    <DataTable
      data={data}
      columns={columns}
      keyExtractor={(user) => user.id}
      selectable
      selectedRows={selected}
      onSelectionChange={setSelected}
      sortable
      defaultSortKey={sortKey}
      defaultSortDirection={sortDir}
      onSort={(key, dir) => {
        setSortKey(key);
        setSortDir(dir);
      }}
      striped
      bordered
      hoverable
      dense
      stickyHeader
    />
  );
}` />
    </section>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Edge Cases & Accessibility</h2>
      <div class="prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-400">
        <ul class="space-y-3">
          <li><strong>Empty data</strong> — Renders customizable empty state with icon, title, and description.</li>
          <li><strong>Loading state</strong> — Shows animated spinner with status text while data loads.</li>
          <li><strong>Indeterminate selection</strong> — "Select all" checkbox shows indeterminate state when some (not all) rows are selected.</li>
          <li><strong>Long text</strong> — Cell text truncates with tooltip on hover; use <code>width</code> on columns to control overflow.</li>
          <li><strong>Keyboard navigation</strong> — Tab navigates through cells and controls; Space to toggle checkboxes, Enter/click to expand rows.</li>
          <li><strong>Responsive</strong> — Horizontal scroll for wide tables on mobile; dense mode for compact layouts.</li>
          <li><strong>ARIA</strong> — Checkboxes include <code>aria-label</code> for screen readers; expand buttons label expanded/collapsed state.</li>
          <li><strong>Row click</strong> — <code>onRowClick</code> callback for clickable rows; stop propagation on interactive cells to avoid conflicts.</li>
        </ul>
      </div>
    </section>

    <StorybookPreview
      url={storybookUrl}
      title="DataTable Component"
  currentPath={currentPath}
    />
  </div>
</DocLayout>

<script>
</script>
