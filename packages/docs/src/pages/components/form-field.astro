---
import DocLayout from '../../layouts/DocLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';
import LiveFormFieldDemo from '../../components/react/LiveFormFieldDemo';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = base + 'components/form-field';
---

<DocLayout
  title="FormField"
  status="stable"
  description="A wrapper component for consistent form field layout and styling. Handles labels, error messages, help text, and required/optional indicators."
  currentPath={currentPath}
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>FormField</code> component provides consistent layout for form controls. It wraps any input component
      with a label, optional required indicator, help text, and error message. It supports both vertical and horizontal
      layouts and three size variants.
    </p>
  </section>

  <section>
    <h2 id="live-demo">Live Demo</h2>
    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <LiveFormFieldDemo client:load />
    </div>
  </section>

  <section>
    <h2 id="props">Props</h2>
    <h3>FormField Props</h3>
    <PropsTable
      rows={[
        { name: 'label', type: 'string', default: '-', description: 'Label text for the form field.' },
        { name: 'error', type: 'string', default: '-', description: 'Error message displayed below children.' },
        { name: 'helpText', type: 'string', default: '-', description: 'Help text displayed below children.' },
        { name: 'required', type: 'boolean', default: 'false', description: 'Shows a red asterisk next to the label.' },
        { name: 'showOptional', type: 'boolean', default: 'false', description: 'Shows "(optional)" text next to label.' },
        { name: 'htmlFor', type: 'string', default: '-', description: 'HTML for attribute linking label to input id.' },
        { name: 'children', type: 'React.ReactNode', default: '-', description: 'The form input/control to wrap.' },
        { name: 'disabled', type: 'boolean', default: 'false', description: 'Applies disabled styling to the label.' },
        { name: 'size', type: '"sm" | "md" | "lg"', default: '"md"', description: 'Size variant.' },
        { name: 'layout', type: '"vertical" | "horizontal"', default: '"vertical"', description: 'Layout direction.' },
        { name: 'showRequiredIndicator', type: 'boolean', default: 'true', description: 'Controls asterisk visibility on required fields.' },
      ]}
    />
  </section>

  <section>
    <h2 id="form-group">FormGroup</h2>
    <p>
      The <code>FormGroup</code> component groups related form fields with an optional title and description.
      It can also render a divider at the bottom for visual separation.
    </p>
    <PropsTable
      rows={[
        { name: 'title', type: 'string', default: '-', description: 'Title for the form group.' },
        { name: 'description', type: 'string', default: '-', description: 'Description text for the group.' },
        { name: 'children', type: 'React.ReactNode', default: '-', description: 'Child form fields.' },
        { name: 'divider', type: 'boolean', default: 'false', description: 'Adds a bottom border divider.' },
      ]}
    />
  </section>

  <section>
    <h2 id="usage">Usage</h2>
    <CodeBlock title="form-field-basic.tsx" code={`import { FormField, FormGroup, Input } from '@storyhouse/components';

export function BasicForm() {
  return (
    <FormGroup title="Contact Information" description="How can we reach you?">
      <FormField label="Email" required>
        <Input type="email" placeholder="you@example.com" />
      </FormField>
      <FormField label="Phone" helpText="Optional. For urgent notifications.">
        <Input type="tel" placeholder="+1 (555) 000-0000" />
      </FormField>
    </FormGroup>
  );
}`} />

    <h3>Horizontal Layout</h3>
    <CodeBlock title="form-field-horizontal.tsx" code={`import { FormField, Input } from '@storyhouse/components';

export function HorizontalFormField() {
  return (
    <FormField label="Full Name" layout="horizontal">
      <Input placeholder="John Doe" className="max-w-xs" />
    </FormField>
  );
}`} />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases</h2>
    <h3>Error + Help Text</h3>
    <p>When both <code>error</code> and <code>helpText</code> are provided, only the error message is shown. Help text is suppressed to avoid confusion.</p>

    <h3>Required + Optional</h3>
    <p>The <code>required</code> and <code>showOptional</code> props are mutually exclusive visually. If both are set, only the required asterisk is shown.</p>

    <h3>No Label</h3>
    <p>When <code>label</code> is omitted, the component renders only the children and help/error text without a label element.</p>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <p>Explore all variants in Storybook:</p>
    <StorybookPreview id="components-form-field--default" title="FormField — Storybook" height="500" />
  </section>
</DocLayout>
