---
import DocLayout from '../../layouts/DocLayout.astro';
import PropsTable from '../../components/PropsTable.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import StorybookPreview from '../../components/StorybookPreview.astro';
import LiveInputDemo from '../../components/react/LiveInputDemo';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
const currentPath = `${base}components/input`;
---

<DocLayout
  title="Input"
  status="stable"
  description="Form input component with labels, validation states, icons, and full accessibility support."
>
  <section>
    <h2 id="overview">Overview</h2>
    <p>
      The <code>Input</code> component provides a feature-rich form input with built-in label support, error states,
      helper text, optional icon slots, and comprehensive ARIA attributes for accessibility.
    </p>
  </section>

  <section>
    <h2 id="live-demo">Live Demo</h2>
    <p>Try the Input component in action — including validation, icons, and sizes.</p>
    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <LiveInputDemo client:load />
    </div>
  </section>

  <section>
    <h2 id="basic">Basic Usage</h2>
    <p>A simple text input with a label and placeholder.</p>

    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <div class="flex flex-col gap-1.5 w-fit">
        <label for="input-basic-example" class="text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
        <input id="input-basic-example" type="email" placeholder="you@example.com" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-base text-gray-900 transition-colors placeholder:text-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20 disabled:cursor-not-allowed disabled:opacity-50 disabled:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:placeholder:text-gray-500 dark:focus:border-orange-400" />
      </div>
    </div>

    <CodeBlock title="input-basic.tsx" code={`import { Input } from '@storyhouse/components';

export function InputBasic() {
  return (
    <Input
      label="Email"
      type="email"
      placeholder="you@example.com"
    />
  );
}`} />
  </section>

  <section>
    <h2 id="sizes">Sizes</h2>
    <p>Three sizes accommodate different layout densities.</p>

    <div class="my-6 flex flex-col gap-4 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <div class="flex flex-col gap-1.5 w-fit">
        <label for="input-size-sm" class="text-sm font-medium text-gray-700 dark:text-gray-300">Small</label>
        <input id="input-size-sm" placeholder="Small" class="w-full rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-900 transition-colors placeholder:text-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100" />
      </div>
      <div class="flex flex-col gap-1.5 w-fit">
        <label for="input-size-md" class="text-sm font-medium text-gray-700 dark:text-gray-300">Medium</label>
        <input id="input-size-md" placeholder="Medium" class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-base text-gray-900 transition-colors placeholder:text-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100" />
      </div>
      <div class="flex flex-col gap-1.5 w-fit">
        <label for="input-size-lg" class="text-sm font-medium text-gray-700 dark:text-gray-300">Large</label>
        <input id="input-size-lg" placeholder="Large" class="w-full rounded-lg border border-gray-300 bg-white px-6 py-3 text-lg text-gray-900 transition-colors placeholder:text-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100" />
      </div>
    </div>

    <CodeBlock title="input-sizes.tsx" code={`import { Input } from '@storyhouse/components';

export function InputSizes() {
  return (
    <div className="flex flex-col gap-4">
      <Input size="sm" placeholder="Small" />
      <Input size="md" placeholder="Medium" />
      <Input size="lg" placeholder="Large" />
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="states">States</h2>

    <h3>Error State</h3>
    <p>Use the <code>error</code> prop to show validation feedback. Error messages are announced by screen readers via <code>role="alert"</code>.</p>

    <div class="my-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
      <div class="flex flex-col gap-1.5 w-fit">
        <label for="input-error-example" class="text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
        <input id="input-error-example" type="email" value="invalid" aria-invalid="true" class="w-full rounded-lg border border-red-300 bg-white px-4 py-2 text-base text-gray-900 transition-colors placeholder:text-gray-400 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/20 dark:border-red-700 dark:bg-gray-900 dark:text-gray-100" />
        <p id="input-error-example-error" role="alert" class="text-sm text-red-600 dark:text-red-400">Please enter a valid email address.</p>
      </div>
    </div>

    <CodeBlock title="input-error.tsx" code={`import { Input } from '@storyhouse/components';

export function InputError() {
  return (
    <Input
      label="Email"
      type="email"
      value="invalid"
      error="Please enter a valid email address."
    />
  );
}`} />

    <h3>Helper Text</h3>
    <p>Use the <code>helperText</code> prop for contextual guidance below the input.</p>

    <CodeBlock title="input-helper.tsx" code={`import { Input } from '@storyhouse/components';

export function InputHelper() {
  return (
    <Input
      label="Password"
      type="password"
      helperText="Must be at least 8 characters."
    />
  );
}`} />

    <h3>Disabled State</h3>
    <p>Disabled inputs show reduced opacity and prevent user interaction.</p>

    <CodeBlock title="input-disabled.tsx" code={`import { Input } from '@storyhouse/components';

export function InputDisabled() {
  return (
    <Input
      label="Username"
      value="johndoe"
      disabled
    />
  );
}`} />
  </section>

  <section>
    <h2 id="full-width">Full Width</h2>
    <p>Set <code>fullWidth</code> to make the input span its container — essential for responsive forms and search bars.</p>

    <CodeBlock title="input-fullwidth.tsx" code={`import { Input } from '@storyhouse/components';

export function InputFullWidth() {
  return (
    <div className="w-full">
      <Input label="Search" placeholder="Type to search..." fullWidth />
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="icons">Icon Slots</h2>
    <p>Add icons inside the input using <code>leftIcon</code> and <code>rightIcon</code> props.</p>

    <CodeBlock title="input-icons.tsx" code={`import { Input } from '@storyhouse/components';

export function InputIcons() {
  return (
    <div className="flex flex-col gap-4">
      <Input
        label="Search"
        placeholder="Type to search..."
        leftIcon={<SearchIcon />}
      />
      <Input
        label="Password"
        type="password"
        rightIcon={<EyeIcon />}
      />
    </div>
  );
}`} />
  </section>

  <section>
    <h2 id="edge-cases">Edge Cases &amp; Error States</h2>

    <h3>Very Long Placeholder Text</h3>
    <p>
      Long placeholder text does not wrap — it overflows horizontally with a standard input. Keep
      placeholders concise (under 40 characters). For longer contextual hints, use <code>helperText</code>.
    </p>

    <h3>Both Icons Simultaneously</h3>
    <p>
      <code>leftIcon</code> and <code>rightIcon</code> can be used together. The left icon gets <code>pl-10</code>
      padding, the right icon gets <code>pr-10</code> padding. Both use <code>pointer-events-none</code> so
      clicks pass through to the input.
    </p>

    <CodeBlock title="input-dual-icons.tsx" code={`import { Input } from '@storyhouse/components';

export function InputDualIcons() {
  return (
    <Input
      label="Search"
      leftIcon={<SearchIcon />}
      rightIcon={<ClearIcon />}
    />
  );
}`} />

    <h3>Label Auto-ID Collisions</h3>
    <p>
      The label's auto-generated <code>id</code> is derived by lowercasing and hyphenating the label text.
      If you have multiple inputs with the same label on one page (e.g., two form sections both labeled "Email"),
      provide explicit <code>id</code> props to avoid ID collisions.
    </p>

    <CodeBlock title="input-custom-id.tsx" code={`import { Input } from '@storyhouse/components';

export function InputCustomId() {
  return (
    <>
      <Input label="Email" id="billing-email" />
      <Input label="Email" id="shipping-email" />
    </>
  );
}`} />

    <h3>Error/Helper Interaction</h3>
    <p>
      When both <code>error</code> and <code>helperText</code> are provided, only the error message is shown.
      Helper text is hidden to avoid confusion. When the error is cleared (set to <code>undefined</code>),
      the helper text reappears automatically.
    </p>

    <CodeBlock title="input-error-cleared.tsx" code={`import React from 'react';
import { Input } from '@storyhouse/components';

export function InputWithValidation() {
  const [value, setValue] = React.useState('');
  const error = value.length > 0 && value.length < 3
    ? 'Must be at least 3 characters.'
    : undefined;

  return (
    <Input
      label="Username"
      value={value}
      onChange={(e) => setValue(e.target.value)}
      error={error}
      helperText="Choose a unique username."
    />
  );
}`} />
  </section>

  <section>
    <h2 id="best-practices">Best Practices &amp; Usage Guidelines</h2>

    <h3>Form Design</h3>
    <ul>
      <li>Always provide a <code>label</code> — placeholder text is not a replacement for labels</li>
      <li>Use <code>type="email"</code>, <code>type="tel"</code>, <code>type="url"</code> for mobile-optimized keyboards</li>
      <li>Show validation errors on blur (when the user leaves the field), not while typing</li>
      <li>Use <code>helperText</code> for format hints, <code>error</code> for validation feedback</li>
      <li>Keep forms to a single column for better readability and mobile usability</li>
    </ul>

    <h3>Validation Timing</h3>
    <p>
      For the best UX, validate on blur (not on every keystroke). Show errors inline next to the
      relevant field, not as a separate error summary. Clear the error when the user starts correcting
      it — re-validate on the next blur or submit.
    </p>

    <h3>Search Inputs</h3>
    <p>
      When using Input as a search field:
    </p>
    <ul>
      <li>Use <code>leftIcon</code> with a search magnifying glass icon</li>
      <li>Set <code>type="search"</code> for proper semantics</li>
      <li>Consider <code>fullWidth</code> for expanded search bars</li>
      <li>Use <code>debounce</code> (300ms) on <code>onChange</code> for async search</li>
    </ul>

    <h3>Accessibility</h3>
    <ul>
      <li>Every input must have a label (visible or via <code>aria-label</code>)</li>
      <li>Error states set <code>aria-invalid="true"</code> on the input element</li>
      <li>Error and helper messages use <code>aria-describedby</code> linking</li>
      <li>Error messages use <code>role="alert"</code> for screen reader announcement</li>
      <li>Icon containers use <code>pointer-events-none</code> to prevent focus interference</li>
    </ul>
  </section>

  <section>
    <h2 id="implementation">Implementation Details</h2>

    <h3>Auto-ID Generation</h3>
    <p>
      The component generates an <code>id</code> from the label text by lowercasing and replacing
      whitespace with hyphens. This auto-generated ID is used for <code>htmlFor</code> on the label
      and for <code>aria-describedby</code> linking to error and helper text elements.
    </p>

    <h3>ARIA Binding</h3>
    <p>
      When <code>error</code> is provided, the input gets <code>aria-invalid="true"</code> and
      <code>aria-describedby</code> pointing to the error message element. When <code>helperText</code>
      is provided (without error), <code>aria-describedby</code> points to the helper element.
      If both are provided, error takes priority in description linking.
    </p>

    <h3>Dark Mode</h3>
    <p>
      Input uses dark mode variants across border colors, background, text, and placeholder.
      Focus ring colors also dark-adapt: <code>focus:border-orange-500</code> becomes
      <code>dark:focus:border-orange-400</code>. Error states use red-300/red-700 borders
      and red-600/red-400 text for dark mode.
    </p>
  </section>

  <section>
    <h2 id="props">Props</h2>
    <PropsTable
      rows={[
        { name: 'label', type: 'string', default: '-', description: 'Label text rendered above the input. Auto-generates an id.' },
        { name: 'error', type: 'string', default: '-', description: 'Error message. Shows red border and alert text when set.' },
        { name: 'helperText', type: 'string', default: '-', description: 'Helper text shown below the input (hidden when error is set).' },
        { name: 'size', type: '"sm" | "md" | "lg"', default: '"md"', description: 'Input height and text size.' },
        { name: 'fullWidth', type: 'boolean', default: 'false', description: 'Spans 100% of parent width.' },
        { name: 'leftIcon', type: 'React.ReactNode', default: '-', description: 'Icon rendered inside the input on the left side.' },
        { name: 'rightIcon', type: 'React.ReactNode', default: '-', description: 'Icon rendered inside the input on the right side.' },
        { name: 'id', type: 'string', default: '-', description: 'Custom id. Auto-generated from label if not provided.' },
        { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables input and reduces opacity.' },
      ]}
    />
    <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">All standard <code>&lt;input&gt;</code> attributes (type, placeholder, value, onChange, etc.) are also supported.</p>
  </section>

  <section>
    <h2 id="accessibility">Accessibility</h2>
    <ul>
      <li>Label is properly associated via <code>htmlFor</code> matching the input <code>id</code></li>
      <li>Error messages use <code>aria-describedby</code> linking and <code>role="alert"</code></li>
      <li><code>aria-invalid</code> is set automatically when the <code>error</code> prop is provided</li>
      <li>Helper text and error are properly differentiated via <code>aria-describedby</code></li>
      <li>Disabled state uses <code>cursor-not-allowed</code> and reduced opacity</li>
      <li>Icon containers use <code>pointer-events-none</code> to prevent input interference</li>
    </ul>
  </section>

  <section>
    <h2 id="storybook-preview">Interactive Preview</h2>
    <p>Explore all Input variants and props interactively in Storybook:</p>
    <StorybookPreview id="components-input--default" title="Input — Storybook" height="500" />
  </section>
</DocLayout>
