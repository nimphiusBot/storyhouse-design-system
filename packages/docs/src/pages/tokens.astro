---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
---

<Layout title="Design Tokens" description="Explore the Storyhouse design tokens — colors, typography, spacing, and shadows.">
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-white">Design Tokens</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Design tokens are the visual atoms of the design system — colors, typography, spacing, and shadows.
        They're available as CSS custom properties and JavaScript exports.
      </p>
    </div>

    <div class="mt-12 mx-auto max-w-3xl space-y-6">
      <a href={`${base}tokens/colors`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl" style="background: linear-gradient(135deg, #f97316, #ef4444, #a855f7, #3b82f6)">
            <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Colors</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Brand orange palette, neutral grays, and semantic colors for success, warning, danger, and info states.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Browse colors →</span>
          </div>
        </div>
      </a>

      <a href={`${base}tokens/typography`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-blue-100 dark:bg-blue-950">
            <svg class="h-7 w-7 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h18M3 8h12m-9 4h6m-6 4h6m-6 4h6" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Typography</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">Font families (Inter, JetBrains Mono), size scale, weight spectrum, line height, and letter spacing tokens.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Browse typography →</span>
          </div>
        </div>
      </a>

      <a href={`${base}tokens/spacing`} class="group block rounded-xl border border-gray-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="flex items-start gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-green-100 dark:bg-green-950">
            <svg class="h-7 w-7 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Spacing &amp; Shadows</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">4px-grid spacing scale from 0 to 24rem, box shadows, drop shadows, border radius, and opacity tokens.</p>
            <span class="mt-3 inline-flex text-sm font-medium text-orange-600 group-hover:text-orange-500 dark:text-orange-400">Browse tokens →</span>
          </div>
        </div>
      </a>
    </div>

    <div class="mt-16 mx-auto max-w-3xl rounded-xl border border-gray-200 bg-gray-50 p-8 dark:border-gray-800 dark:bg-gray-900">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Using Tokens</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        Import the tokens CSS file in your app to access all variables globally:
      </p>
      <pre class="mt-4 rounded-lg bg-gray-900 px-4 py-3 text-sm text-gray-100"><code>@import '@storyhouse/tokens/tokens.css';</code></pre>
      <p class="mt-4 text-gray-600 dark:text-gray-400">
        Or use the JavaScript exports for programmatic access:
      </p>
      <pre class="mt-4 rounded-lg bg-gray-900 px-4 py-3 text-sm text-gray-100"><code>{`import { colors, typography, spacing, shadows } from '@storyhouse/tokens';`}</code></pre>
    </div>
  </div>
</Layout>
