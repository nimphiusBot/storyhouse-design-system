---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
---

<Layout>
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl">Components</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        Browse the Storyhouse design system component library.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Button</h3>
        <p class="mt-2 text-sm text-gray-600">Versatile button component with multiple variants, sizes, and states.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Card</h3>
        <p class="mt-2 text-sm text-gray-600">Flexible card container for grouping related content.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Input</h3>
        <p class="mt-2 text-sm text-gray-600">Form input with labels, validation states, and accessibility built in.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Badge</h3>
        <p class="mt-2 text-sm text-gray-600">Small status indicators for counts, labels, and states.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Avatar</h3>
        <p class="mt-2 text-sm text-gray-600">User avatar with image fallback and initials support.</p>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900">Interactive Playground</h2>
      <p class="mt-2 text-gray-600">
        Try out the components live in our <a href={`${base}storybook/`} class="text-blue-600 hover:underline">Storybook</a>.
      </p>
    </div>
  </div>
</Layout>
