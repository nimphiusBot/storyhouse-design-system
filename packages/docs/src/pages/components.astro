---

<Layout title="Components" description="Browse the Storyhouse design system component library — <strong>{components.length} components</strong> and growing.">
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-white">Components</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Browse all {components.length} Storyhouse design system components. Each component is production-ready with comprehensive testing, accessibility, and documentation.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {components.map((c) => (
        <a
          href={`${base}components/${c.href}`}
          class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800"
        >
          <div class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${c.bgColor}`}>
            <svg class={`h-6 w-6 ${c.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={c.icon} />
            </svg>
          </div>
          <div class="flex items-center gap-2">
            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">{c.title}</h3>
            <StatusBadge status={c.status} />
          </div>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{c.description}</p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {c.tags.map((tag) => (
              <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16">
      <div class="rounded-xl border border-gray-200 bg-gradient-to-br from-orange-50 to-gray-50 p-8 text-center shadow-sm dark:border-gray-800 dark:from-orange-950/20 dark:to-gray-950">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Interactive Playground</h2>
        <p class="mt-3 text-gray-600 dark:text-gray-400">
          Try each component live with all props and variants in our Storybook instance.
        </p>
        <a
          href={`${base}storybook/`}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center justify-center rounded-lg bg-orange-500 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-orange-600"
        >
          <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M16.71.243l-.12 2.711a.18.18 0 00.29.144l1.19-1.014.78.637c.12.1.296.064.376-.052l.18-2.733 1.284-.266L20.5 0H3.595l-.092 3.53h16.38l-.357 4.42H3.767l-.45 5.16h16.363l-.564 6.896-6.836 1.94-6.05-1.94-.388-4.346H3.212l.5 5.56 6.992 2.5 1.17.38 6.38-1.82.72-8.37h-14.7l.45-5.53h14.7l.57-6.883z"/>
          </svg>
          Open Storybook
        </a>
      </div>
    </div>
  </div>
</Layout>
