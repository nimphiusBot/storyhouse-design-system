---
import Layout from '../layouts/Layout.astro';
import StatusBadge from '../components/StatusBadge.astro';
const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';
---

<Layout title="Components" description="Browse the Storyhouse design system component library — <strong>16 components</strong> and growing.">
  <div class="py-12">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-white">Components</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Browse the Storyhouse design system component library. Each component is production-ready with comprehensive testing, accessibility, and documentation.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <a href={`${base}components/button`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-950">
          <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Button</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Versatile button component with multiple variants, sizes, and states. Supports loading, icons, and full-width layouts.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-300">4 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">3 sizes</span>
        </div>
      </a>

      <a href={`${base}components/card`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100 dark:bg-green-950">
          <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Card</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Flexible card container for grouping related content. Composable sub-components for header, title, content, and footer.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700 dark:bg-green-950 dark:text-green-300">4 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">4 sub-components</span>
        </div>
      </a>

      <a href={`${base}components/input`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100 dark:bg-purple-950">
          <svg class="h-6 w-6 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Input</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Form input with labels, validation states, icons, and accessibility built in. Supports error, helper text, and icon slots.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-purple-50 px-2 py-0.5 text-xs font-medium text-purple-700 dark:bg-purple-950 dark:text-purple-300">3 sizes</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">ARIA native</span>
        </div>
      </a>

      <a href={`${base}components/badge`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-orange-100 dark:bg-orange-950">
          <svg class="h-6 w-6 text-orange-600 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Badge</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Small status indicators for counts, labels, and states. Supports variants, dot indicators, and removable tags.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-orange-50 px-2 py-0.5 text-xs font-medium text-orange-700 dark:bg-orange-950 dark:text-orange-300">6 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Removable</span>
        </div>
      </a>

      <a href={`${base}components/avatar`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-pink-100 dark:bg-pink-950">
          <svg class="h-6 w-6 text-pink-600 dark:text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Avatar</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">User avatar with image, initials fallback, and deterministic color generation. Five sizes, two shapes.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-pink-50 px-2 py-0.5 text-xs font-medium text-pink-700 dark:bg-pink-950 dark:text-pink-300">5 sizes</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">2 shapes</span>
        </div>
      </a>

      <!-- Row 2: New Batch 1 -->
      <a href={`${base}components/checkbox`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-100 dark:bg-cyan-950">
          <svg class="h-6 w-6 text-cyan-600 dark:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Checkbox</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Form input for selection with support for individual and grouped checkboxes, indeterminate states, and validation.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-cyan-50 px-2 py-0.5 text-xs font-medium text-cyan-700 dark:bg-cyan-950 dark:text-cyan-300">4 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">3 sizes</span>
        </div>
      </a>

      <a href={`${base}components/select`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-950">
          <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Select</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Styled select dropdown with option groups, validation states, and keyboard navigation.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:bg-indigo-950 dark:text-indigo-300">4 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Grouped options</span>
        </div>
      </a>

      <a href={`${base}components/tabs`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-rose-100 dark:bg-rose-950">
          <svg class="h-6 w-6 text-rose-600 dark:text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Tabs</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Tab navigation for organizing content into switchable panels. Supports icons, badges, and pills variant.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-rose-50 px-2 py-0.5 text-xs font-medium text-rose-700 dark:bg-rose-950 dark:text-rose-300">2 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Icons + badges</span>
        </div>
      </a>

      <a href={`${base}components/modal`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-yellow-100 dark:bg-yellow-950">
          <svg class="h-6 w-6 text-yellow-600 dark:text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Modal</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Modal dialog for focused interactions. Supports sizes, variants, loading state, and ConfirmModal.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-0.5 text-xs font-medium text-yellow-700 dark:bg-yellow-950 dark:text-yellow-300">5 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">6 sizes</span>
        </div>
      </a>

      <a href={`${base}components/toast`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-lime-100 dark:bg-lime-950">
          <svg class="h-6 w-6 text-lime-600 dark:text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Toast</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Non-intrusive notification messages that auto-dismiss. Supports success, error, warning, and info types.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-lime-50 px-2 py-0.5 text-xs font-medium text-lime-700 dark:bg-lime-950 dark:text-lime-300">4 types</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Hook API</span>
        </div>
      </a>

      <a href={`${base}components/tooltip`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-violet-100 dark:bg-violet-950">
          <svg class="h-6 w-6 text-violet-600 dark:text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Tooltip</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Hover tooltip with four positions and configurable delay for contextual information display.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-violet-50 px-2 py-0.5 text-xs font-medium text-violet-700 dark:bg-violet-950 dark:text-violet-300">4 positions</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">500ms delay</span>
        </div>
      </a>

      <a href={`${base}components/pagination`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-teal-100 dark:bg-teal-950">
          <svg class="h-6 w-6 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 9h.01M14 9h.01M18 9h.01M6 9h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Pagination</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Navigate large datasets with page numbers, page size control, and compact variant.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-teal-50 px-2 py-0.5 text-xs font-medium text-teal-700 dark:bg-teal-950 dark:text-teal-300">2 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Ellipsis truncation</span>
        </div>
      </a>

      <a href={`${base}components/datatable`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-sky-100 dark:bg-sky-950">
          <svg class="h-6 w-6 text-sky-600 dark:text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Data Table</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Feature-rich data table with sorting, selection, expandable rows, striped mode, and custom rendering.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-sky-50 px-2 py-0.5 text-xs font-medium text-sky-700 dark:bg-sky-950 dark:text-sky-300">Sortable</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Selectable rows</span>
        </div>
      </a>

      <a href={`${base}components/emptystate`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-100 dark:bg-red-950">
          <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
        </div>
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400">Empty State</h3>
          <StatusBadge status="stable" />
        </div>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Flexible empty state for no data, no results, errors, permission denials, and loading with optional actions.</p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 dark:bg-red-950 dark:text-red-300">5 variants</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">Action buttons</span>
        </div>
      </a>

      <a href={`${base}components/file-upload`} class="group rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md hover:border-orange-200 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-orange-800">
