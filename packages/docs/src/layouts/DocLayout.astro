---
import Layout from './Layout.astro';

export interface SidebarSection {
  title: string;
  links: { href: string; label: string }[];
}

export interface Props {
  title: string;
  description?: string;
  sidebar?: SidebarSection[];
  currentPath?: string;
  status?: 'stable' | 'beta' | 'deprecated' | 'alpha';
}

const { title, description, sidebar = [], currentPath = '', status } = Astro.props;
// Ensure base always has trailing slash so `${base}path` produces correct URLs
const base = (import.meta.env.BASE_URL || '/storyhouse-design-system/').replace(/\/?$/, '/');

const defaultSidebar: SidebarSection[] = [
  {
    title: 'Getting Started',
    links: [
      { href: `${base}guides/getting-started`, label: 'Installation' },
      { href: `${base}guides/theming`, label: 'Theming Guide' },
      { href: `${base}guides/utilities`, label: 'Utilities' },
      { href: `${base}guides/contributing`, label: 'Contributing' },
      { href: `${base}guides/patterns`, label: 'Common Patterns' },
      { href: `${base}guides/migration`, label: 'Migration Guide' },
    ],
  },
  {
    title: 'Components',
    links: [
      { href: `${base}components/accordion`, label: 'Accordion' },
      { href: `${base}components/alert`, label: 'Alert' },
      { href: `${base}components/auto-refresh-indicator`, label: 'Auto Refresh' },
      { href: `${base}components/avatar`, label: 'Avatar' },
      { href: `${base}components/badge`, label: 'Badge' },
      { href: `${base}components/breadcrumb`, label: 'Breadcrumb' },
      { href: `${base}components/button`, label: 'Button' },
      { href: `${base}components/card`, label: 'Card' },
      { href: `${base}components/checkbox`, label: 'Checkbox' },
      { href: `${base}components/chip`, label: 'Chip' },
      { href: `${base}components/collapsible`, label: 'Collapsible' },
      { href: `${base}components/datatable`, label: 'Data Table' },
      { href: `${base}components/date-time-picker`, label: 'Date Time Picker' },
      { href: `${base}components/duration-slider`, label: 'Duration Slider' },
      { href: `${base}components/emptystate`, label: 'Empty State' },
      { href: `${base}components/error-boundary`, label: 'Error Boundary' },
      { href: `${base}components/file-upload`, label: 'File Upload' },
      { href: `${base}components/filter-bar`, label: 'Filter Bar' },
      { href: `${base}components/form-field`, label: 'Form Field' },
      { href: `${base}components/format-select`, label: 'Format Select' },
      { href: `${base}components/icon-button`, label: 'Icon Button' },
      { href: `${base}components/input`, label: 'Input' },
      { href: `${base}components/modal`, label: 'Modal' },
      { href: `${base}components/page-header`, label: 'Page Header' },
      { href: `${base}components/pagination`, label: 'Pagination' },
      { href: `${base}components/progress-bar`, label: 'Progress Bar' },
      { href: `${base}components/radio`, label: 'Radio' },
      { href: `${base}components/select`, label: 'Select' },
      { href: `${base}components/skeleton`, label: 'Skeleton' },
      { href: `${base}components/slide-out-panel`, label: 'Slide-Out Panel' },
      { href: `${base}components/slide-panel`, label: 'Slide Panel' },
      { href: `${base}components/social-icon`, label: 'Social Icon' },
      { href: `${base}components/spinner`, label: 'Spinner' },
      { href: `${base}components/stepper`, label: 'Stepper' },
      { href: `${base}components/tabs`, label: 'Tabs' },
      { href: `${base}components/textarea`, label: 'Textarea' },
      { href: `${base}components/thumbnail-lightbox`, label: 'Thumbnail Lightbox' },
      { href: `${base}components/toast`, label: 'Toast' },
      { href: `${base}components/toggle-switch`, label: 'Toggle Switch' },
      { href: `${base}components/tooltip`, label: 'Tooltip' },
    ],
  },
  {
    title: 'Design Tokens',
    links: [
      { href: `${base}tokens/colors`, label: 'Colors' },
      { href: `${base}tokens/typography`, label: 'Typography' },
      { href: `${base}tokens/spacing`, label: 'Spacing & Shadows' },
    ],
  },
];

const sections = sidebar.length > 0 ? sidebar : defaultSidebar;

const statusConfig = {
  stable: { label: 'Stable', classes: 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300' },
  beta: { label: 'Beta', classes: 'bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300' },
  alpha: { label: 'Alpha', classes: 'bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-300' },
  deprecated: { label: 'Deprecated', classes: 'bg-red-100 text-red-700 dark:bg-red-950 dark:text-red-300' },
};
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex gap-12 py-10">
      <!-- Mobile sidebar toggle button -->
      <button
        id="sidebar-toggle"
        class="fixed bottom-6 right-6 z-40 flex h-12 w-12 items-center justify-center rounded-full bg-orange-500 text-white shadow-lg transition-all hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 lg:hidden"
        aria-label="Toggle navigation"
      >
        <svg id="sidebar-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="sidebar-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Overlay backdrop for mobile -->
      <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 backdrop-blur-sm lg:hidden" />

      <!-- Sidebar -->
      <aside id="doc-sidebar" class="fixed inset-y-0 left-0 z-40 w-64 -translate-x-full transform border-r border-gray-200 bg-white p-6 shadow-xl transition-transform duration-200 ease-in-out overflow-y-auto lg:static lg:z-auto lg:w-56 lg:translate-x-0 lg:border-r-0 lg:bg-transparent lg:p-0 lg:shadow-none dark:border-gray-800 dark:bg-gray-950 dark:lg:bg-transparent">
        <div class="flex items-center justify-between lg:hidden">
          <span class="text-sm font-semibold text-gray-500 dark:text-gray-400">Navigation</span>
          <button id="sidebar-close-btn" class="rounded-lg p-1 text-gray-400 hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-800" aria-label="Close navigation">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <nav class="mt-4 space-y-8 lg:mt-0 lg:sticky lg:top-24">
          {
            sections.map((section) => (
              <div>
                <h4 class="mb-2 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{section.title}</h4>
                <ul class="space-y-0.5">
                  {
                    section.links.map((link) => {
                      const isActive = currentPath === link.href;
                      return (
                        <li>
                          <a
                            href={link.href}
                            class:list={[
                              'block rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
                              isActive
                                ? 'bg-orange-50 text-orange-700 dark:bg-orange-950/30 dark:text-orange-400'
                                : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white',
                            ]}
                          >
                            {link.label}
                          </a>
                        </li>
                      );
                    })
                  }
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <!-- Content -->
      <article class="min-w-0 flex-1">
        <div class="prose-storyhouse max-w-3xl">
          <div class="flex items-center gap-3 !mt-0">
            <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
            {status && statusConfig[status] && (
              <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${statusConfig[status].classes}`}>
                {statusConfig[status].label}
              </span>
            )}
          </div>
          {description && <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">{description}</p>}
          <slot />
        </div>
      </article>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('doc-sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const closeBtn = document.getElementById('sidebar-close-btn');
  const iconOpen = document.getElementById('sidebar-icon-open');
  const iconClose = document.getElementById('sidebar-icon-close');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  toggle?.addEventListener('click', function() {
    if (sidebar?.classList.contains('-translate-x-full')) {
      openSidebar();
    } else {
      closeSidebar();
    }
  });
  overlay?.addEventListener('click', closeSidebar);
  closeBtn?.addEventListener('click', closeSidebar);

  // Close on link click (mobile)
  sidebar?.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      if (window.innerWidth < 1024) closeSidebar();
    });
  });
})();
</script>
