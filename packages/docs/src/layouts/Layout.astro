---
import '../styles/globals.css';

const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Storyhouse Design System` : 'Storyhouse Design System';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base.replace(/\/$/, '')}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}

    <script is:inline>
      // Dark mode — apply immediately to prevent flash
      (function() {
        const stored = localStorage.getItem('storyhouse-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-white text-gray-900 transition-colors duration-200 dark:bg-gray-950 dark:text-gray-100">
    <header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-sm dark:border-gray-800 dark:bg-gray-950/80">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center gap-8">
            <a href={base} class="flex items-center gap-2 text-xl font-bold tracking-tight text-gray-900 dark:text-white">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-orange-500 text-sm font-bold text-white">S</span>
              Storyhouse
            </a>
            <nav class="hidden sm:flex sm:space-x-1">
              <a
                href={base}
                class="rounded-md px-3 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
              >
                Home
              </a>
              <a
                href={`${base}components`}
                class="rounded-md px-3 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
              >
                Components
              </a>
              <a
                href={`${base}guides`}
                class="rounded-md px-3 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
              >
                Guides
              </a>
              <a
                href={`${base}tokens`}
                class="rounded-md px-3 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
              >
                Tokens
              </a>
            </nav>
          </div>
          <div class="flex items-center gap-3">
            <a
              href={`${base}storybook/`}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden rounded-lg bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-200 sm:inline-flex dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
            >
              <svg class="mr-1.5 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M16.71.243l-.12 2.711a.18.18 0 00.29.144l1.19-1.014.78.637c.12.1.296.064.376-.052l.18-2.733 1.284-.266L20.5 0H3.595l-.092 3.53h16.38l-.357 4.42H3.767l-.45 5.16h16.363l-.564 6.896-6.836 1.94-6.05-1.94-.388-4.346H3.212l.5 5.56 6.992 2.5 1.17.38 6.38-1.82.72-8.37h-14.7l.45-5.53h14.7l.57-6.883z"/>
              </svg>
              Storybook
            </a>
            <button
              id="theme-toggle"
              class="rounded-lg p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
              aria-label="Toggle dark mode"
            >
              <svg class="h-5 w-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
              <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </button>
            <a
              href="https://github.com/nimphiusBot/storyhouse-design-system"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200"
              aria-label="GitHub repository"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid gap-8 md:grid-cols-3">
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Storyhouse Design System</h3>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Built for scale, precision, and exceptional developer experience.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Quick Links</h3>
            <ul class="mt-2 space-y-1">
              <li><a href={`${base}components`} class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Components</a></li>
              <li><a href={`${base}guides/getting-started`} class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Getting Started</a></li>
              <li><a href={`${base}storybook/`} class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Storybook</a></li>
              <li><a href={`${base}tokens`} class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Design Tokens</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Resources</h3>
            <ul class="mt-2 space-y-1">
              <li><a href="https://github.com/nimphiusBot/storyhouse-design-system" class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">GitHub</a></li>
              <li><a href={`${base}guides/theming`} class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Theming Guide</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-gray-200 pt-8 dark:border-gray-800">
          <p class="text-center text-sm text-gray-400 dark:text-gray-500">© 2024 Storyhouse Design System. Built with precision.</p>
        </div>
      </div>
    </footer>
    <script>
      // Dark mode toggle
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          const html = document.documentElement;
          const isDark = html.classList.toggle('dark');
          localStorage.setItem('storyhouse-theme', isDark ? 'dark' : 'light');
        });
      }
    </script>
  </body>
</html>
