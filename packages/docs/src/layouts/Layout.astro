---
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Storyhouse Design System</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center">
            <a href="/" class="text-xl font-bold text-gray-900">Storyhouse</a>
            <nav class="ml-10 flex space-x-4">
              <a href="/" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100">Home</a>
              <a href="/components" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100">Components</a>
              <a href="/guides" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100">Guides</a>
              <a href="/api" class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100">API</a>
            </nav>
          </div>
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>
    <footer class="border-t border-gray-200 bg-white py-8">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm text-gray-500">
          © 2024 Storyhouse Design System. Built with precision.
        </p>
      </div>
    </footer>
  </body>
</html>