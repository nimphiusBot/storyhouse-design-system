---
export interface Props {
  status: 'stable' | 'beta' | 'deprecated' | 'alpha';
  size?: 'sm' | 'md';
}

const { status, size = 'sm' } = Astro.props;

const config = {
  stable: {
    label: 'Stable',
    classes: 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300',
  },
  beta: {
    label: 'Beta',
    classes: 'bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300',
  },
  alpha: {
    label: 'Alpha',
    classes: 'bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-300',
  },
  deprecated: {
    label: 'Deprecated',
    classes: 'bg-red-100 text-red-700 dark:bg-red-950 dark:text-red-300',
  },
}[status];

const sizeClasses = size === 'sm'
  ? 'px-2 py-0.5 text-xs'
  : 'px-2.5 py-1 text-sm';
---

<span class={`inline-flex items-center rounded-full font-medium ${config.classes} ${sizeClasses}`}>
  {config.label}
</span>
