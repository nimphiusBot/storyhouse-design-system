---
export interface Props {
  /** Storybook story ID (e.g. "components-button--primary") */
  id?: string;
  /** Direct URL to the Storybook page (alternative to id) */
  url?: string;
  title?: string;
  height?: string;
}

const { id, url, title = 'Interactive Preview', height = '400' } = Astro.props;
const base = import.meta.env.BASE_URL || '/storyhouse-design-system/';

// Build the iframe URL — prefer direct URL if provided, otherwise construct from ID
const storybookIframeUrl = url
  ? url
  : `${base}storybook/iframe.html?id=${id || 'undefined'}&viewMode=story`;

// Build the "Open in Storybook" link
const storybookSplashUrl = url
  ? url.replace('/iframe.html?', '/?path=/story/')
  : `${base}storybook/?path=/story/${id}`;
---

<div class="my-6 overflow-hidden rounded-xl border border-gray-200 shadow-sm dark:border-gray-800">
  <div class="flex items-center justify-between border-b border-gray-200 bg-gray-50 px-4 py-2 dark:border-gray-800 dark:bg-gray-900">
    <div class="flex items-center gap-2">
      <span class="flex h-3 w-3 rounded-full bg-red-400" aria-hidden="true" />
      <span class="flex h-3 w-3 rounded-full bg-yellow-400" aria-hidden="true" />
      <span class="flex h-3 w-3 rounded-full bg-green-400" aria-hidden="true" />
      <span class="ml-3 text-xs font-medium text-gray-500 dark:text-gray-400">{title}</span>
    </div>
    <a
      href={storybookSplashUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-medium text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-orange-300"
    >
      Open in Storybook →
    </a>
  </div>
  <iframe
    src={storybookIframeUrl}
    title={`Storybook preview: ${title}`}
    style={{ width: '100%', height: `${height}px`, border: 'none' }}
    class="block bg-white dark:bg-gray-950"
    loading="lazy"
    sandbox="allow-scripts allow-same-origin"
  />
</div>
