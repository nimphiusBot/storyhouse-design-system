{
  "name": "@storyhouse/tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Design tokens for Storyhouse Design System (colors, typography, spacing, shadows)",
  "author": "Design System Platform Engineer",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist && npm run build:css",
    "build:css": "node scripts/generate-css.js",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}